---
import MainLayout from "../layouts/MainLayout.astro";
import TeamMemberCard from "../components/TeamMemberCard.astro";

const team = [
  {
    name: "Łukasz Dutka",
    role: "Lead Developer",
    affiliation: "AGH University of Science and Technology",
    bio: "Core architect of the Onedata platform, specializing in distributed storage systems and high-performance data access.",
    avatar:
      "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=300&h=300&fit=crop&crop=face",
  },
  {
    name: "Łukasz Opioła",
    role: "System Architect",
    affiliation: "AGH University of Science and Technology",
    bio: "Designing the distributed system foundations and protocols that enable Onedata's cross-site federation and reliability.",
    avatar:
      "https://images.unsplash.com/photo-1560250097-0b93528c311a?w=300&h=300&fit=crop&crop=face",
  },
  {
    name: "Michał Wrzeszcz",
    role: "Backend Engineer",
    affiliation: "AGH University of Science and Technology",
    bio: "Expert in distributed systems and metadata management, driving the development of Onedata's core services.",
    avatar:
      "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=300&h=300&fit=crop&crop=face",
  },
  {
    name: "Bartosz Kryza",
    role: "Integration & APIs",
    affiliation: "AGH University of Science and Technology",
    bio: "Leading the design of Onedata APIs and integration layers enabling seamless connection with external services and HPC systems.",
    avatar:
      "https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=300&h=300&fit=crop&crop=face",
  },
  {
    name: "Bartosz Walkowicz",
    role: "Backend Engineer",
    affiliation: "AGH University of Science and Technology",
    bio: "Developing core backend logic for data workflows, automation pipelines and orchestration within the Onedata ecosystem.",
    avatar:
      "https://images.unsplash.com/photo-1531427186611-ecfd6d936c79?w=300&h=300&fit=crop&crop=face",
  },
  {
    name: "Michał Stanisz",
    role: "Backend Engineer",
    affiliation: "AGH University of Science and Technology",
    bio: "Working on data consistency, replication protocols and internal storage engine reliability across Onedata clusters.",
    avatar:
      "https://images.unsplash.com/photo-1542909168-82c3e7fdca5c?w=300&h=300&fit=crop&crop=face",
  },
  {
    name: "Darin Nikołow",
    role: "Backend Engineer",
    affiliation: "AGH University of Science and Technology",
    bio: "Contributing to the development of Oneprovider and Onezone services, focusing on scalability and interoperability.",
    avatar:
      "https://images.unsplash.com/photo-1547425260-76bcadfb4f2c?w=300&h=300&fit=crop&crop=face",
  },
  {
    name: "Jakub Liput",
    role: "Frontend Engineer",
    affiliation: "AGH University of Science and Technology",
    bio: "Building the web interface and user-facing tools that make complex distributed data management accessible to researchers.",
    avatar:
      "https://images.unsplash.com/photo-1519345182560-3f2917c472ef?w=300&h=300&fit=crop&crop=face",
  },
  {
    name: "Agnieszka Raczek",
    role: "Frontend Engineer",
    affiliation: "AGH University of Science and Technology",
    bio: "Crafting responsive, accessible interfaces and improving the overall user experience across the Onedata web applications.",
