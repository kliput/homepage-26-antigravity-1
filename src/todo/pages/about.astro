      "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=300&h=300&fit=crop&crop=face",
  },
  {
    name: "Jakub Karczewski",
    role: "Frontend Engineer",
    affiliation: "AGH University of Science and Technology",
