---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import { ArrowLeft, Calendar } from "@lucide/astro";

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<MainLayout
  title={`${entry.data.title} | Onedata Blog`}
  description={entry.data.description}
>
  <article class="blog-post">
    <div class="post-container container">
      <!-- TODO: obrazek -->
      <div class="post-content od-card">
        {
          entry.data.image && (
            <div class="post-image card-image mb-8 rounded-xl">
              <img src={entry.data.image} alt={entry.data.title} />
            </div>
          )
        }

        <header class="post-header">
          <div
            class="post-meta od-border mb-6 flex items-center gap-4 border-b pb-6"
          >
            {
              entry.data.tags && (
                <div class="tags">
                  {entry.data.tags.map((tag) => (
                    <span class="tag inline-block rounded-full bg-gradient-to-r from-violet-600 to-purple-400 px-3 py-1 text-xs font-semibold text-white">
                      {tag}
                    </span>
                  ))}
                </div>
              )
            }
            <div class="time-meta flex items-center gap-2">
              <Calendar class="h-4 w-4" />
              <time
                class="text-xs text-muted"
                datetime={entry.data.date.toISOString()}
              >
                {
                  entry.data.date.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })
                }
              </time>
            </div>
          </div>
          <h1 class="post-title">{entry.data.title}</h1>
          <div class="text-muted">{entry.data.description}</div>
        </header>

        <Content />

        {
          entry.data.citationBibtex && (
            <>
              <h2>Citation</h2>
              <pre class="citation rounded-xl">{entry.data.citationBibtex}</pre>
            </>
          )
        }
      </div>

      <hr />
      <a href="/blog" class="back-link">
        <ArrowLeft class="h-4 w-4" /> Back to All Posts
      </a>
    </div>
  </article>
</MainLayout>

<style is:global>
  .post-container {
    max-width: 800px;
    margin: 0 auto;
    padding-top: 3rem;
    padding-bottom: 5rem;
  }

  .post-image {
    /* border-radius: var(--radius-lg); */
    height: 24rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 2rem;
    color: var(--od-text);
    opacity: 0.7;
    font-weight: 500;
    font-size: 0.95rem;
  }

  .back-link:hover {
    color: var(--primary);
    opacity: 1;
    text-decoration: none;
  }

  /* .post-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--od-text);
    opacity: 0.8;
  } */

  .post-title {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 2.5rem;
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .post-title {
      font-size: 3rem;
    }
  }

  /* Markdown Content Styles */
  .post-content {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--od-text);
  }

  .post-content h1,
  .post-content h2,
  .post-content h3,
  .post-content h4 {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .post-content h2 {
    font-size: 1.75rem;
  }
  .post-content h3 {
    font-size: 1.5rem;
  }

  .post-content p {
    margin-bottom: 1.5rem;
  }

  .post-content a {
    color: var(--primary);
  }

  .post-content ul,
  .post-content ol {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
  }

  .post-content li {
    margin-bottom: 0.5rem;
  }

  .post-content pre {
    background-color: #1e1e1e;
    color: #d4d4d4;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .post-content code {
    font-family: var(--font-family-mono);
    padding: 0.2em 0.4em;
    border-radius: 3px;
    font-size: 0.9em;
  }

  .post-content pre code {
    background-color: transparent;
    padding: 0;
  }

  .post-content blockquote {
    border-left: 4px solid var(--primary);
    padding-left: 1.5rem;
    margin-left: 0;
    margin-right: 0;
    font-style: italic;
    opacity: 0.9;
  }

  pre.citation {
    margin-top: 2.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    background-color: var(--od-bg-2);
    border-width: 1px;
    border-color: var(--od-border);
    color: var(--od-text-muted);
    padding: 1.25rem;
    font-family: var(--font-family-mono);
    white-space: pre-wrap;
  }
</style>
