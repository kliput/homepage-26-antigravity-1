---
import ApiLayout from "../../../../layouts/ApiLayout.astro";
import { marked } from "marked";
import { getAbsoluteApiPath } from "../../../../utils/api/api.ts";
import { type RequestParameter } from "../../../../components/ApiSchemaBody.astro";
import ApiSchemaBody from "../../../../components/ApiSchemaBody.astro";
import { getStaticPaths } from "../../../../utils/api/get-static-paths.ts";
import ApiSchemaTable from "../../../../components/ApiSchemaTable.astro";
import ApiHttpResponseCode from "../../../../components/ApiHttpResponseCode.astro";
import ApiBodyTag from "../../../../components/ApiBodyTag.astro";
import ApiRequestExamples from "../../../../components/ApiRequestExamples.astro";
import { type ApiProductString } from "../../../../utils/types.ts";

export { getStaticPaths };

const { version, operation, swaggerData, redirectDestination } = Astro.props;

const product = Astro.props.product as ApiProductString;
const products: readonly ApiProductString[] = Object.freeze([
  "onezone",
  "oneprovider",
  "onepanel",
]);

if (!products.includes(product)) {
  throw new Error(`Unknown product in API page: ${product}`);
}

if (redirectDestination) {
  return Astro.redirect(redirectDestination);
}

// Reconstruct Sidebar groups for current product
const apiPaths = swaggerData.paths || {};
const groupsMap = new Map();
Object.entries(apiPaths).forEach(
  // FIXME: redundancy with getStaticPaths
  ([endpointPattern, methods]: [string, any]) => {
    Object.entries(methods).forEach(([method, op]: [string, any]) => {
      const groupName = op.tags && op.tags.length > 0 ? op.tags[0] : "General";
      const slug = `operation/${op.operationId}`;

      if (!groupsMap.has(groupName)) {
        groupsMap.set(groupName, { name: groupName, operations: [] });
      }
      groupsMap.get(groupName).operations.push({
        href: getAbsoluteApiPath(version, product, slug),
        method,
        summary: op.summary || endpointPattern,
        deprecated: op.deprecated,
      });
    });
  },
);
const sidebarGroups = Array.from(groupsMap.values());
const pageTitle = operation
  ? `${operation.summary} | API Reference`
  : `${product.toUpperCase()} API Reference`;

// FIXME: lepiej byłoby to rozbić na dwa osobne komponenty, gdzie jest operation
// i overview (lub więcej, jeśli będzie taka potrzeba)

// FIXME: globalnie użyć sanitizera wyjścia marked np. DOMPurify.sanitize, albo przejść
// na parser używany przez astro

function swaggerUrl(product: ApiProductString, version: string) {
  return `https://get.onedata.org/api/${version}/${product}.json`;
}

function descriptionMarkdownToHtml(
  markdownContent: string,
  product: ApiProductString,
  version: string,
): string {
  let finalMarkdownContent = markdownContent;
  finalMarkdownContent = finalMarkdownContent.replace(
    "../../../swagger/onezone/swagger.json",
    swaggerUrl(product, version),
  );
  return marked.parse(finalMarkdownContent, { async: false });
}

const overviewHtml =
  !operation &&
  swaggerData?.info?.description &&
  descriptionMarkdownToHtml(swaggerData.info.description, product, version);
---

<ApiLayout
  title={pageTitle}
  version={version}
  activeProduct={product}
  sidebarGroups={sidebarGroups}
>
  {
    operation ? (
      <div class="api-endpoint-details">
        <h1 class="api-endpoint-title">
          {operation.summary}
          {operation.deprecated && (
            <span class="ml-3 inline-flex items-center rounded-md bg-red-500/10 px-2 py-1 align-middle text-sm font-medium text-red-500 ring-1 ring-inset ring-red-500/20">
              Deprecated
            </span>
          )}
        </h1>
        <div class="api-endpoint-path od-bg-input od-border od-text mb-4 overflow-x-auto rounded-xl border p-4 font-mono leading-relaxed">
          <span
            class={`method-badge method-${operation.method}`}
            style="margin-right: 1rem; font-size: 0.9rem;"
          >
            {operation.method.toUpperCase()}
          </span>
          {operation.endpointPath}
        </div>

        {operation.details.description && (
          <div
            class="prose mb-12 max-w-none dark:prose-invert"
            set:html={marked.parse(operation.details.description)}
          />
        )}

        {/* Request Format */}
        {operation.details.parameters &&
          operation.details.parameters.length > 0 &&
          (() => {
            const consumes = operation.details.consumes || swaggerData.consumes;

            const pathParams: any[] = [];
            const queryParams: any[] = [];
            const headerParams: any[] = [];
            const formDataParams: any[] = [];
            const bodyParams: any[] = [];

            for (const p of operation.details.parameters) {
              if (p.in === "path") pathParams.push(p);
              else if (p.in === "query") queryParams.push(p);
              else if (p.in === "header") headerParams.push(p);
              else if (p.in === "formData") formDataParams.push(p);
              else if (p.in === "body") bodyParams.push(p);
            }

            const renderParamsTable = (title: string, params: any[]) => {
              if (!params || params.length === 0) return null;
              return (
                <div class="api-section mt-12">
                  <div class="mb-4 flex items-end justify-between border-b border-[var(--od-border)] pb-2">
                    <h2 class="!mb-0 !border-0 !pb-0 text-xl font-bold">
                      {title}
                    </h2>
                  </div>
                  <div class="mt-4 overflow-x-auto">
                    <table class="w-full border-collapse text-left">
                      <thead class="border-b border-[var(--od-border-hover)] text-sm text-[var(--od-text)]">
                        <tr class="text-left font-semibold">
                          <th class="w-1/3 p-3">Parameter</th>
                          <th class="2-2/3 p-3">Type & Description</th>
                        </tr>
                      </thead>
                      <tbody class="text-sm">
                        {params.map((param: any) => (
                          <tr class="hover:bg-[var(--od-bg-hover)]">
                            <td class="p-3 font-mono font-medium text-[var(--od-text)]">
                              <span>{param.name}</span>
                              {param.required && (
                                <ApiBodyTag colorStyle="red" text="required" />
                              )}
                            </td>
                            <td class="p-3">
                              <div class="font-mono text-xs text-[var(--od-text-muted)]">
                                {param.type ||
                                  (param.schema && param.schema.type) ||
                                  "string"}
                              </div>
                              {param.description && (
                                <div
                                  class="prose prose-sm dark:prose-invert"
                                  set:html={marked.parse(param.description)}
                                />
                              )}
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              );
            };

            return (
              <>
                {renderParamsTable("Path parameters", pathParams)}
                {renderParamsTable("Query parameters", queryParams)}
                {renderParamsTable("Header parameters", headerParams)}
                {renderParamsTable("Form parameters", formDataParams)}

                {bodyParams && bodyParams.length > 0 && (
                  <div class="api-section mt-12">
                    <div class="mb-4 flex items-end justify-between border-b border-[var(--od-border)] pb-2">
                      <h2 class="!mb-0 !border-0 !pb-0 text-xl font-bold">
                        Request body
                      </h2>
                      {consumes && consumes.length > 0 && (
                        <div class="text-sm">
                          {consumes.map((c: string) => (
                            <span class="ml-2 inline-block rounded border border-[var(--od-border)] bg-[var(--od-bg-input)] px-2 py-1 font-mono text-xs text-[var(--od-text)]">
                              {c}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                    {bodyParams?.map((param: RequestParameter) => (
                      <ApiSchemaBody
                        requestParameter={param}
                        swaggerData={swaggerData}
                        collapsed={true}
                      />
                    ))}
                  </div>
                )}
              </>
            );
          })()}

        {/* Request Examples */}
        <ApiRequestExamples operation={operation} swaggerData={swaggerData} />

        {/* Responses */}
        {operation.details.responses &&
          Object.keys(operation.details.responses).length > 0 && (
            <div class="api-section mt-12">
              <div class="mb-4 flex items-end justify-between border-b border-[var(--od-border)] pb-2">
                <h2 class="!mb-0 !border-0 !pb-0 text-xl font-bold">
                  Responses
                </h2>
                <div class="text-sm">
                  <span class="ml-2 inline-block rounded border border-[var(--od-border)] bg-[var(--od-bg-input)] px-2 py-1 font-mono text-xs text-[var(--od-text)]">
                    application/json
                  </span>
                </div>
              </div>

              <div class="mt-4 space-y-6">
                {Object.entries(operation.details.responses).map(
                  ([code, response]: [string, any]) => (
                    <div class="od-card rounded-xl border border-[var(--od-border)] bg-[var(--od-bg-card)] p-6">
                      <div class="flex items-baseline gap-3">
                        <ApiHttpResponseCode code={code} />
                        {response.description ? (
                          <div
                            class="mb-4"
                            set:html={marked.parse(response.description)}
                          />
                        ) : (
                          <div class="italic text-[var(--od-text-muted)]">
                            No description.
                          </div>
                        )}
                      </div>

                      {response.schema && (
                        <ApiSchemaTable
                          schema={response.schema}
                          swaggerData={swaggerData}
                          collapsed={true}
                        />
                      )}

                      {response.examples && (
                        <div class="mt-4">
                          <h4 class="mb-2 text-sm font-semibold text-[var(--od-text-muted)]">
                            Examples
                          </h4>
                          {Object.entries(response.examples).map(
                            ([mime, example]) => (
                              <div class="mt-2 overflow-hidden rounded-xl border border-[#2d2d2d] bg-[#1e1e1e]">
                                <div class="border-b border-[#404040] bg-[#2d2d2d] px-4 py-2 font-mono text-xs text-gray-300">
                                  {mime}
                                </div>
                                <div class="overflow-x-auto p-4 text-sm text-gray-300">
                                  <code>
                                    {typeof example === "string"
                                      ? example
                                      : JSON.stringify(example, null, 2)}
                                  </code>
                                </div>
                              </div>
                            ),
                          )}
                        </div>
                      )}
                    </div>
                  ),
                )}
              </div>
            </div>
          )}
      </div>
    ) : (
      <div class="api-welcome pt-4">
        {/* FIXME: show custom h1 if swagger description doesn't have h1 */}
        {/* <h1 class="api-endpoint-title" style="text-transform: capitalize;">
          {product} API Reference
        </h1> */}
        {overviewHtml && (
          <div
            class="prose mb-12 max-w-none dark:prose-invert"
            set:html={overviewHtml}
          />
        )}

        {swaggerData?.securityDefinitions &&
          Object.keys(swaggerData.securityDefinitions).length > 0 && (
            <div class="api-section mt-12">
              <h2>Authentication</h2>
              <div class="mt-6 space-y-6">
                {Object.entries(swaggerData.securityDefinitions).map(
                  ([key, def]: [string, any]) => (
                    <div class="od-card rounded-xl border border-[var(--od-border)] bg-[var(--od-bg-card)] p-6">
                      <h3 class="mb-4 text-lg font-bold text-[var(--od-text)]">
                        {key}
                      </h3>
                      <ul class="mb-4 list-disc pl-5 text-sm text-[var(--od-text-muted)]">
                        <li>
                          <strong>Type:</strong> {def.type}
                        </li>
                        {def.name && (
                          <li>
                            <strong>Name:</strong> {def.name}
                          </li>
                        )}
                        {def.in && (
                          <li>
                            <strong>In:</strong> {def.in}
                          </li>
                        )}
                      </ul>
                      {def.description && (
                        <div
                          class="prose max-w-none text-sm dark:prose-invert"
                          set:html={marked.parse(def.description)}
                        />
                      )}
                    </div>
                  ),
                )}
              </div>
            </div>
          )}
      </div>
    )
  }
</ApiLayout>

<style is:global>
  .api-description {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    color: var(--od-text);
  }

  .api-section h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--od-border);
    color: var(--od-text);
  }
</style>
