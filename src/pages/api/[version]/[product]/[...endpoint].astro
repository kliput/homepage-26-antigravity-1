---
import ApiLayout from "../../../../layouts/ApiLayout.astro";
import fs from "node:fs";
import path from "node:path";
import { marked } from "marked";

export async function getStaticPaths() {
  const apiDir = path.join(process.cwd(), "api");
  if (!fs.existsSync(apiDir)) {
    console.warn("API root directory not found");
    return [];
  }

  const versions = fs
    .readdirSync(apiDir)
    .filter((f) => fs.statSync(path.join(apiDir, f)).isDirectory())
    .sort((a, b) => b.localeCompare(a));

  let paths: any[] = [];

  for (const version of versions) {
    const versionDir = path.join(apiDir, version);
    const products = ["onezone", "oneprovider", "onepanel"];

    for (const product of products) {
      const swaggerPath = path.join(versionDir, `${product}.json`);
      if (!fs.existsSync(swaggerPath)) {
        console.warn(`API ${version} ${product} not found`);
        continue;
      }

      try {
        const swaggerData = JSON.parse(fs.readFileSync(swaggerPath, "utf8"));
        const apiPaths = swaggerData.paths || {};

        // Group operations
        const groupsMap = new Map();

        Object.entries(apiPaths).forEach(
          ([endpointPattern, methods]: [string, any]) => {
            Object.entries(methods).forEach(([method, op]: [string, any]) => {
              const groupName =
                op.tags && op.tags.length > 0 ? op.tags[0] : "General";
              const endpointSlug = endpointPattern
                .replace(/^\//, "")
                .replace(/\/+/g, "-")
                .replace(/[{}]/g, "");
              const slug = `${endpointSlug}-${method}`;

              if (!groupsMap.has(groupName)) {
                groupsMap.set(groupName, { name: groupName, operations: [] });
              }

              const operationData = {
                href: `/api/${version}/${product}/${slug}`,
                method,
                summary: op.summary || endpointPattern,
                endpointPath: endpointPattern,
                details: op,
              };

              groupsMap.get(groupName).operations.push(operationData);

              paths.push({
                params: { version, product, endpoint: slug },
                props: {
                  version,
                  product,
                  operation: operationData,
                  swaggerData,
                },
              });
            });
          },
        );

        // Add index path for the product dashboard (default to first endpoint or empty)
        paths.push({
          params: { version, product, endpoint: undefined },
          props: { version, product, operation: null, swaggerData },
        });
      } catch (e) {
        console.error(`Error processing ${swaggerPath}`, e);
      }
    }
  }

  // Need to pass availableVersions and sidebarGroups correctly to each page
  // We'll reconstruct sidebarGroups dynamically inside the component instead to simplify getStaticPaths

  return paths;
}

const { version, product, operation, swaggerData } = Astro.props;

// Reconstruct Sidebar groups for current product
const apiPaths = swaggerData.paths || {};
const groupsMap = new Map();
Object.entries(apiPaths).forEach(
  ([endpointPattern, methods]: [string, any]) => {
    Object.entries(methods).forEach(([method, op]: [string, any]) => {
      const groupName = op.tags && op.tags.length > 0 ? op.tags[0] : "General";
      const endpointSlug = endpointPattern
        .replace(/^\//, "")
        .replace(/\/+/g, "-")
        .replace(/[{}]/g, "");
      const slug = `${endpointSlug}-${method}`;

      if (!groupsMap.has(groupName)) {
        groupsMap.set(groupName, { name: groupName, operations: [] });
      }
      groupsMap.get(groupName).operations.push({
        href: `/api/${version}/${product}/${slug}`,
        method,
        summary: op.summary || endpointPattern,
      });
    });
  },
);
const sidebarGroups = Array.from(groupsMap.values());

// Calculate versions dynamically from fs here or pass from getStaticPaths
const apiDir = path.join(process.cwd(), "api");
const availableVersions = fs
  .readdirSync(apiDir)
  .filter((f) => fs.statSync(path.join(apiDir, f)).isDirectory())
  .sort((a, b) => b.localeCompare(a));

function resolveSchemaRef(schema: any, rootConfig: any): any {
  if (!schema || !schema.$ref) return schema;
  const refPath = schema.$ref.replace(/^#\//, "");
  const parts = refPath.split("/");
  let target = rootConfig;
  for (const part of parts) {
    if (!target) return undefined;
    target = target[part];
  }
  return target || schema;
}

const pageTitle = operation
  ? `${operation.summary} | API Reference`
  : `${product.toUpperCase()} API Reference`;
---

<ApiLayout
  title={pageTitle}
  version={version}
  availableVersions={availableVersions}
  activeProduct={product}
  sidebarGroups={sidebarGroups}
>
  {
    operation ? (
      <div class="api-endpoint-details">
        <h1 class="api-endpoint-title">{operation.summary}</h1>
        <div class="api-endpoint-path">
          <span
            class={`method-badge method-${operation.method}`}
            style="margin-right: 1rem; font-size: 0.9rem;"
          >
            {operation.method.toUpperCase()}
          </span>
          {operation.endpointPath}
        </div>

        {operation.details.description && (
          <div
            class="prose mb-12 max-w-none dark:prose-invert"
            set:html={marked.parse(operation.details.description)}
          />
        )}

        {/* Request Format */}
        {operation.details.parameters &&
          operation.details.parameters.length > 0 &&
          (() => {
            const consumes = operation.details.consumes || swaggerData.consumes;
            return (
              <div class="api-section mt-12">
                <div class="mb-4 flex items-end justify-between border-b border-[var(--od-border)] pb-2">
                  <h2 class="!mb-0 !border-0 !pb-0 text-xl font-bold">
                    Parameters
                  </h2>
                  {consumes && consumes.length > 0 && (
                    <div class="text-sm">
                      <span class="text-[var(--od-text-muted)]">
                        Consumes:{" "}
                      </span>
                      {consumes.map((c: string) => (
                        <span class="ml-2 inline-block rounded border border-[var(--od-border)] bg-[var(--od-bg-input)] px-2 py-1 font-mono text-xs text-[var(--od-text)]">
                          {c}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
                <div class="mt-4 overflow-x-auto">
                  <table class="w-full border-collapse text-left">
                    <thead>
                      <tr class="border-b border-[var(--od-border)] text-sm text-[var(--od-text)]">
                        <th class="p-3 font-semibold">Name</th>
                        <th class="p-3 font-semibold">In</th>
                        <th class="p-3 font-semibold">Type</th>
                        <th class="p-3 font-semibold">Required</th>
                        <th class="p-3 font-semibold">Description</th>
                      </tr>
                    </thead>
                    <tbody class="text-sm">
                      {operation.details.parameters.map((param: any) => (
                        <tr class="border-b border-[var(--od-border)] hover:bg-[var(--od-bg-hover)]">
                          <td class="p-3 font-mono font-medium text-[var(--od-text)]">
                            {param.name}
                          </td>
                          <td class="p-3 text-[var(--od-text-muted)]">
                            {param.in}
                          </td>
                          <td class="p-3 font-mono text-[var(--od-text-muted)]">
                            {param.type ||
                              (param.schema && param.schema.type) ||
                              "object"}
                          </td>
                          <td class="p-3">
                            {param.required ? (
                              <span class="font-bold text-red-500">Yes</span>
                            ) : (
                              <span class="text-[var(--od-text-muted)]">
                                No
                              </span>
                            )}
                          </td>
                          <td class="min-w-[300px] p-3 align-top">
                            {param.description && (
                              <div
                                class="prose prose-sm dark:prose-invert"
                                set:html={marked.parse(param.description)}
                              />
                            )}

                            {param.schema &&
                              (() => {
                                const resolved = resolveSchemaRef(
                                  param.schema,
                                  swaggerData,
                                );
                                if (resolved && resolved.properties) {
                                  return (
                                    <div class="mt-4 rounded-lg border border-[var(--od-border-light)] bg-[var(--od-bg-input)] p-4 text-sm shadow-sm">
                                      <h4 class="mb-3 text-xs font-bold uppercase tracking-wider text-[var(--od-text)]">
                                        Schema Properties{" "}
                                        {param.schema.$ref ? (
                                          <span class="ml-2 font-mono font-normal lowercase text-[var(--od-text-muted)]">
                                            ({param.schema.$ref})
                                          </span>
                                        ) : (
                                          ""
                                        )}
                                      </h4>
                                      <ul class="m-0 list-none space-y-4 p-0">
                                        {Object.entries(
                                          resolved.properties,
                                        ).map(
                                          ([propName, propDef]: [
                                            string,
                                            any,
                                          ]) => (
                                            <li class="m-0 p-0">
                                              <div class="flex items-center justify-between font-mono text-sm font-medium text-[var(--od-accent)]">
                                                <span>{propName}</span>
                                                <span class="text-xs font-normal text-[var(--od-text-muted)]">
                                                  {propDef.type ||
                                                    (propDef.$ref
                                                      ? "object"
                                                      : "any")}
                                                </span>
                                              </div>
                                              {propDef.description && (
                                                <div
                                                  class="prose prose-sm mb-0 mt-1.5 leading-snug opacity-90 dark:prose-invert"
                                                  set:html={marked.parse(
                                                    propDef.description,
                                                  )}
                                                />
                                              )}
                                            </li>
                                          ),
                                        )}
                                      </ul>
                                    </div>
                                  );
                                }
                                return null;
                              })()}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            );
          })()}

        {/* Request Examples */}
        {operation.details["x-code-samples"] &&
          operation.details["x-code-samples"].length > 0 && (
            <div class="api-section mt-12">
              <h2>Request Examples</h2>
              <div class="mt-4 space-y-6">
                {operation.details["x-code-samples"].map((sample: any) => (
                  <div class="overflow-hidden rounded-xl border border-[#2d2d2d] bg-[#1e1e1e]">
                    <div class="border-b border-[#404040] bg-[#2d2d2d] px-4 py-2 text-xs font-bold text-gray-300">
                      {sample.lang}
                    </div>
                    <pre class="overflow-x-auto p-4 text-sm">
                      <code class="text-gray-300">{sample.source}</code>
                    </pre>
                  </div>
                ))}
              </div>
            </div>
          )}

        {/* Responses */}
        {operation.details.responses &&
          Object.keys(operation.details.responses).length > 0 && (
            <div class="api-section mt-12">
              <h2>Responses</h2>
              <div class="mt-4 space-y-6">
                {Object.entries(operation.details.responses).map(
                  ([code, response]: [string, any]) => (
                    <div class="od-card rounded-xl border border-[var(--od-border)] bg-[var(--od-bg-card)] p-6">
                      <div class="mb-4 flex items-center gap-3">
                        <span
                          class={`rounded px-3 py-1 text-sm font-bold ${
                            code.startsWith("2")
                              ? "bg-green-500/10 text-green-500"
                              : code.startsWith("3")
                                ? "bg-blue-500/10 text-blue-500"
                                : code.startsWith("4")
                                  ? "bg-yellow-500/10 text-yellow-500"
                                  : "bg-red-500/10 text-red-500"
                          }`}
                        >
                          {code}
                        </span>
                        <h3 class="text-lg font-bold text-[var(--od-text)]">
                          {response.description || "Response"}
                        </h3>
                      </div>

                      {response.schema && (
                        <div class="mt-4">
                          <h4 class="mb-2 text-sm font-semibold text-[var(--od-text-muted)]">
                            Schema
                          </h4>
                          <pre class="overflow-x-auto rounded-xl border border-[#2d2d2d] bg-[#1e1e1e] p-4 text-sm text-gray-300">
                            <code>
                              {JSON.stringify(response.schema, null, 2)}
                            </code>
                          </pre>
                        </div>
                      )}

                      {response.examples && (
                        <div class="mt-4">
                          <h4 class="mb-2 text-sm font-semibold text-[var(--od-text-muted)]">
                            Examples
                          </h4>
                          {Object.entries(response.examples).map(
                            ([mime, example]) => (
                              <div class="mt-2 overflow-hidden rounded-xl border border-[#2d2d2d] bg-[#1e1e1e]">
                                <div class="border-b border-[#404040] bg-[#2d2d2d] px-4 py-2 font-mono text-xs text-gray-300">
                                  {mime}
                                </div>
                                <pre class="overflow-x-auto p-4 text-sm text-gray-300">
                                  <code>
                                    {typeof example === "string"
                                      ? example
                                      : JSON.stringify(example, null, 2)}
                                  </code>
                                </pre>
                              </div>
                            ),
                          )}
                        </div>
                      )}
                    </div>
                  ),
                )}
              </div>
            </div>
          )}
      </div>
    ) : (
      <div class="api-welcome pt-4">
        {/* FIXME: show custom h1 if swagger description doesn't have h1 */}
        {/* <h1 class="api-endpoint-title" style="text-transform: capitalize;">
          {product} API Reference
        </h1> */}
        {swaggerData?.info?.description && (
          <div
            class="prose mb-12 max-w-none dark:prose-invert"
            set:html={marked.parse(swaggerData.info.description)}
          />
        )}

        {swaggerData?.securityDefinitions &&
          Object.keys(swaggerData.securityDefinitions).length > 0 && (
            <div class="api-section mt-12">
              <h2>Authentication</h2>
              <div class="mt-6 space-y-6">
                {Object.entries(swaggerData.securityDefinitions).map(
                  ([key, def]: [string, any]) => (
                    <div class="od-card rounded-xl border border-[var(--od-border)] bg-[var(--od-bg-card)] p-6">
                      <h3 class="mb-4 text-lg font-bold text-[var(--od-text)]">
                        {key}
                      </h3>
                      <ul class="mb-4 list-disc pl-5 text-sm text-[var(--od-text-muted)]">
                        <li>
                          <strong>Type:</strong> {def.type}
                        </li>
                        {def.name && (
                          <li>
                            <strong>Name:</strong> {def.name}
                          </li>
                        )}
                        {def.in && (
                          <li>
                            <strong>In:</strong> {def.in}
                          </li>
                        )}
                      </ul>
                      {def.description && (
                        <div
                          class="prose max-w-none text-sm dark:prose-invert"
                          set:html={marked.parse(def.description)}
                        />
                      )}
                    </div>
                  ),
                )}
              </div>
            </div>
          )}
      </div>
    )
  }
</ApiLayout>

<style>
  .api-description {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    color: var(--od-text);
  }

  .api-section h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--od-border);
    color: var(--od-text);
  }
</style>
