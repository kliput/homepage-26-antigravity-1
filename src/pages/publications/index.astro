---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const publicationPosts = allPosts
  .filter((post) => post.data.tags?.includes("Publication"))
  .sort((a, b) => {
    // Sort by integer year if available, otherwise by date
    const yearA = a.data.year ? Number(a.data.year) : a.data.date.getFullYear();
    const yearB = b.data.year ? Number(b.data.year) : b.data.date.getFullYear();
    if (yearB !== yearA) return yearB - yearA;
    return b.data.date.valueOf() - a.data.date.valueOf();
  });
---

<MainLayout
  title="Onedata Publications"
  description="Scientific papers and peer-reviewed articles from the Onedata research team."
>
  <div class="pubs-header-section">
    <div class="container text-center">
      <div class="pill">PEER-REVIEWED RESEARCH</div>
      <h1 class="pubs-title">Onedata <span class="highlight">Publications</span></h1>
      <h2 class="pubs-subtitle">
        Scientific papers and peer-reviewed articles from the Onedata research team.
      </h2>
    </div>
  </div>

  <div class="container pubs-content">
    <div class="pubs-list">
      {publicationPosts.map((post) => (
        <div class="pub-card">
          <div class="pub-tags">
            {post.data.journalAbbreviation && <span class="tag-abbr">{post.data.journalAbbreviation}</span>}
            {post.data.impactFactor && <span class="tag-if">IF {post.data.impactFactor}</span>}
            {post.data.year && <span class="tag-year">{post.data.year}</span>}
            {post.data.externalDoiLink && (
              <a href={post.data.externalDoiLink} target="_blank" rel="noopener noreferrer" class="tag-doi" aria-label="DOI Link">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                {post.data.externalDoiLink.replace("https://doi.org/", "")}
              </a>
            )}
          </div>
          <h3 class="pub-title">{post.data.title}</h3>
          <div class="pub-authors">
            {post.data.authors?.join(", ") || ""}
          </div>
          <div class="pub-journal">
            {post.data.journalFullName}
            {post.data.issueDetails ? `, ${post.data.issueDetails}` : ""}
          </div>
          <p class="pub-abstract">
            {post.data.abstract || post.data.description}
          </p>
          <a href={`/publications/${post.slug}`} class="pub-link">
            Full details &amp; cite &rarr;
          </a>
        </div>
      ))}
    </div>
  </div>
</MainLayout>

<style>
  .pubs-header-section {
    padding: 4rem 0 2rem;
    text-align: center;
    background-color: var(--color-bg);
  }

  .text-center {
    text-align: center;
  }

  .pill {
    display: inline-block;
    padding: 0.35rem 1rem;
    border-radius: 9999px;
    background-color: #f3f4f6;
    color: #4b5563;
    font-size: 0.75rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    border: 1px solid #e5e7eb;
    letter-spacing: 0.05em;
  }
  
  html[data-theme="dark"] .pill {
    background-color: rgba(255, 255, 255, 0.05);
    color: #e5e7eb;
    border-color: rgba(255, 255, 255, 0.1);
  }

  .pubs-title {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 1.25rem;
    line-height: 1.1;
  }

  .highlight {
    color: var(--color-primary, #e11d48);
  }

  .pubs-subtitle {
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--color-text);
    opacity: 0.8;
    max-width: 800px;
    margin: 0 auto;
  }

  .pubs-content {
    padding-bottom: 6rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .pubs-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .pub-card {
    border: 1px solid var(--color-border);
    border-radius: 16px;
    background-color: var(--color-bg);
    padding: 2.5rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .pub-card:hover {
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
    transform: translateY(-3px);
  }
  
  html[data-theme="dark"] .pub-card:hover {
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4);
  }

  .pub-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
  }
  
  .tag-abbr {
    font-weight: 700;
    background: var(--color-nav-hover);
    padding: 0.25rem 0.6rem;
    border-radius: 6px;
    border: 1px solid var(--color-border);
  }
  
  .tag-if {
    color: #ea580c;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
  }
  
  .tag-year {
    color: var(--color-text);
    opacity: 0.6;
    font-weight: 500;
  }
  
  .tag-doi {
    color: #3b82f6;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-weight: 500;
  }
  
  .tag-doi:hover {
    text-decoration: underline;
  }
  
  html[data-theme="dark"] .tag-doi {
    color: #60a5fa;
  }

  .pub-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .pub-authors {
    margin-bottom: 0.75rem;
    color: var(--color-text);
    opacity: 0.9;
    font-size: 1.05rem;
  }

  .pub-journal {
    margin-bottom: 1.5rem;
    color: var(--color-text);
    opacity: 0.7;
    font-style: italic;
  }

  .pub-abstract {
    margin-bottom: 1.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    color: var(--color-text);
    opacity: 0.8;
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .pub-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-primary, #e11d48);
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .pub-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }
</style>
