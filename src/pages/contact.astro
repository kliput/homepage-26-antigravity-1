---
import MainLayout from "../layouts/MainLayout.astro";

const contactItems = [
  {
    title: "Email us",
    description: "Drop us a message at info@onedata.org.",
    action: "Send email",
    href: "mailto:info@onedata.org",
    color: "from-red-500 to-orange-500",
    gradientStart: "#ef4444",
    gradientEnd: "#f97316",
    icon: "mail",
  },
  {
    title: "Onedata source code",
    description:
      "For our latest developments and updates, view the source code on GitHub or the changelog. If you find our project useful, please consider starring it on GitHub.",
    action: "View on GitHub",
    href: "https://github.com/onedata/onedata",
    gradientStart: "#f43f5e",
    gradientEnd: "#ef4444",
    icon: "code",
  },
  {
    title: "Bug reports and discussions",
    description:
      "Use GitHub to create an issue for any bugs or feature discussions.",
    action: "Create an issue",
    href: "https://github.com/onedata/onedata/issues",
    gradientStart: "#f97316",
    gradientEnd: "#f59e0b",
    icon: "alert",
  },
  {
    title: "Dedicated support",
    description:
      "Organizations using Onedata may apply for dedicated support including configuring and performance tuning, implementing additional features, and solving problems.",
    action: "Get in touch",
    href: "mailto:info@onedata.org",
    gradientStart: "#dc2626",
    gradientEnd: "#fb7185",
    icon: "users",
  },
];
---

<MainLayout
  title="Contact – Onedata"
  description="Multiple ways to reach the Onedata team and get the support you need."
>
  <div class="contact-page">
    <div class="contact-inner">
      <div class="contact-hero">
        <h1 class="contact-title">Get in touch</h1>
        <p class="contact-subtitle">
          Multiple ways to reach us and get the support you need.
        </p>
      </div>

      <div class="contact-list">
        {
          contactItems.map((item) => (
            <div class="contact-card">
              <div
                class="contact-icon"
                style={`background: linear-gradient(135deg, ${item.gradientStart}, ${item.gradientEnd})`}
              >
                {item.icon === "mail" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="white"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                  </svg>
                )}
                {item.icon === "code" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="white"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="16 18 22 12 16 6" />
                    <polyline points="8 6 2 12 8 18" />
                  </svg>
                )}
                {item.icon === "alert" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="white"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                  </svg>
                )}
                {item.icon === "users" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="white"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                  </svg>
                )}
              </div>
              <div class="contact-card-body">
                <h3 class="contact-card-title">{item.title}</h3>
                <p class="contact-card-desc">{item.description}</p>
                <a
                  href={item.href}
                  class={`contact-action no-external-icon`}
                  target={item.href.startsWith("http") ? "_blank" : undefined}
                  rel={
                    item.href.startsWith("http")
                      ? "noopener noreferrer"
                      : undefined
                  }
                >
                  {item.action}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .contact-page {
    background-color: var(--od-bg);
    min-height: 100vh;
    padding: 5rem 1rem 6rem;
  }

  .contact-inner {
    max-width: 56rem;
    margin: 0 auto;
  }

  .contact-hero {
    margin-bottom: 3.5rem;
  }

  .contact-title {
    font-size: clamp(2.5rem, 6vw, 3.75rem);
    font-weight: 700;
    color: var(--od-text);
    margin-bottom: 0.75rem;
  }

  .contact-subtitle {
    font-size: 1.125rem;
    color: var(--od-text-muted);
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-card {
    background: var(--od-bg-card);
    border: 1px solid var(--od-border);
    border-radius: 1rem;
    padding: 2rem;
    display: flex;
    gap: 1.5rem;
    transition: box-shadow 0.2s;
  }

  .contact-card:hover {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  .contact-icon {
    display: inline-flex;
    padding: 0.75rem;
    border-radius: 0.75rem;
    opacity: 0.9;
    flex-shrink: 0;
    align-self: flex-start;
  }

  .contact-card-body {
    flex: 1;
  }

  .contact-card-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--od-text);
    margin-bottom: 0.5rem;
  }

  .contact-card-desc {
    color: var(--od-text-muted);
    margin-bottom: 1rem;
    line-height: 1.65;
  }

  .contact-action {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--od-accent);
    transition: opacity 0.2s;
    text-decoration: none;
  }

  .contact-action:hover {
    opacity: 0.75;
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .contact-card {
      flex-direction: column;
    }
  }
</style>
