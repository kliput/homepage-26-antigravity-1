---
import MainLayout from "../layouts/MainLayout.astro";
import LandingHero from "../components/LandingHero.astro";
import LandingFeatures from "../components/LandingFeatures.jsx";
import LandingHowItWorks from "../components/LandingHowItWorks.jsx";
import LandingUseCases from "../components/LandingUseCases.jsx";
import LandingContact from "../components/LandingContact.jsx";
import LandingStats from "../components/LandingStats.jsx";
---

<MainLayout
  title="Onedata - Data Management Platform for Distributed AI Pipelines and Hybrid Clouds"
>
  <LandingHero />
  <LandingStats client:visible />
  <LandingFeatures client:visible />
  <LandingHowItWorks client:visible />
  <LandingUseCases client:visible />
  <LandingContact client:visible />
</MainLayout>

<style>
  .hero-section {
    padding: 6rem 0;
    text-align: center;
    background: linear-gradient(180deg, var(--od-glow) 0%, transparent 100%);
  }

  .hero-content {
    max-width: 900px;
    margin: 0 auto;
  }

  .highlight {
    color: var(--od-accent);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 2rem;
    font-size: 1.05rem;
    font-weight: 600;
    border-radius: 8px;
    transition: all 0.2s;
    cursor: pointer;
    text-decoration: none;
  }

  .btn-primary {
    background-color: var(--od-accent);
    color: #ffffff;
    border: 2px solid var(--od-accent);
  }

  .btn-primary:hover {
    background-color: transparent;
    color: var(--od-accent);
    text-decoration: none;
  }

  .btn-outline {
    background-color: transparent;
    color: var(--od-text);
    border: 2px solid var(--border);
  }

  .btn-outline:hover {
    border-color: var(--od-accent);
    color: var(--od-accent);
    text-decoration: none;
  }
</style>
