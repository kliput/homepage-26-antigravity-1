---
import MainLayout from "../layouts/MainLayout.astro";
import LandingHero from "../components/LandingHero.astro";
import LandingNumbers from "../components/LandingNumbers.astro";
import LandingFeatures from "../components/LandingFeatures.astro";
import LandingHowItWorks from "../components/LandingHowItWorks.astro";
---

<MainLayout title="Onedata - Data Management Platform for Distributed AI Pipelines and Hybrid Clouds">
  <LandingHero />
  <LandingNumbers />
  <LandingFeatures />
  <LandingHowItWorks />
</MainLayout>

<style>
  .hero-section {
    padding: 6rem 0;
    text-align: center;
    background: linear-gradient(
      180deg,
      var(--od-glow) 0%,
      transparent 100%
    );
  }

  .hero-content {
    max-width: 900px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 4rem;
    }
  }

  .highlight {
    color: var(--od-accent);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text);
    opacity: 0.8;
    max-width: 700px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 2rem;
    font-size: 1.05rem;
    font-weight: 600;
    border-radius: 8px;
    transition: all 0.2s;
    cursor: pointer;
    text-decoration: none;
  }

  .btn-primary {
    background-color: var(--od-accent);
    color: #ffffff;
    border: 2px solid var(--od-accent);
  }

  .btn-primary:hover {
    background-color: transparent;
    color: var(--od-accent);
    text-decoration: none;
  }

  .btn-outline {
    background-color: transparent;
    color: var(--color-text);
    border: 2px solid var(--color-border);
  }

  .btn-outline:hover {
    border-color: var(--od-accent);
    color: var(--od-accent);
    text-decoration: none;
  }
</style>
