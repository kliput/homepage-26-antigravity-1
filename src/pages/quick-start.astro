---
import MainLayout from "../layouts/MainLayout.astro";
import QuickStartPaths from "../components/QuickStartPaths.astro";
import { ArrowRight, Database, Server, Globe, Key } from "lucide-astro";
import HeroSection from "../components/HeroSection.astro";

const concepts = [
  {
    icon: Database,
    title: "Spaces",
    description:
      "Virtual directories distributed across multiple storage providers. Every file lives in a Space.",
  },
  {
    icon: Server,
    title: "Providers",
    description:
      "Institutions or individuals who contribute storage resources to the network via Oneprovider services.",
  },
  {
    icon: Globe,
    title: "Zones",
    description:
      "Independent Onedata ecosystems federating multiple providers, coordinated by a Onezone service.",
  },
];
---

<MainLayout
  title="Quick Start — Onedata"
  description="Get up and running with Onedata in minutes."
>
  <div class="quick-start-page">
    <!-- FIXME: original design: badgeIcon={BookOpenCheck} badgeText="Getting Started" -->
    <HeroSection
      title="Quick Start"
      description="Get up and running with Onedata in minutes — from logging in to accessing and managing your research data."
    />

    <!-- Basic Concepts -->
    <section class="concepts-section">
      <div class="container max-w-5xl">
        <div class="section-header">
          <h2 class="section-title">Core concepts</h2>
          <p class="section-sub">
            Three building blocks you need to understand before you start.
          </p>
        </div>
        <div class="concepts-grid">
          {
            concepts.map((c) => (
              <div class="concept-card">
                <div class="concept-icon-wrap">
                  <c.icon class="concept-icon" />
                </div>
                <h3 class="concept-title">{c.title}</h3>
                <p class="concept-desc">{c.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Step-by-step -->
    <section class="guide-section">
      <div class="container max-w-4xl">
        <div class="section-header">
          <h2 class="section-title">Step-by-step guide</h2>
          <p class="section-sub">
            Choose your path and follow the steps to get Onedata running your
            way.
          </p>
        </div>
        <QuickStartPaths />
      </div>
    </section>

    <!-- Sandbox token -->
    <section class="token-section">
      <div class="container max-w-3xl">
        <div class="token-card">
          <div class="token-icon-wrap">
            <Key class="token-icon" />
          </div>
          <div class="token-content">
            <h3 class="token-title">Can't see the Sandbox Space?</h3>
            <p class="token-desc">
              If you've logged in to <a
                href="https://demo.onedata.org"
                target="_blank"
                rel="noreferrer">demo.onedata.org</a
              > but don't see the Sandbox in the DATA tab, consume this invite token
              to join the <strong>All users</strong> group:
            </p>
            <div class="token-code" id="sandbox-token">
              MDAxZWxvY2F00aW9uIGRlbW8ub25lZGF00YS5vcmcKMDA3NmlkZW500aWZpZXIgMi9ubWQvdXNyLWMwNWU3M2EwZmE4NzQzOTI1NDE3ZGRjMDMzZTEwZWExY2g4NzQzL3VqZzphbGxfdXNlcnM6LzAyZDRmYTA3NGEwYTNlYTIzNTYwZDc00Yzg00YTA1Mjk1Y2gyYzE5CjAwMmZzaWduYXR1cmUgzFtuZQ5JPZ1KH1d8FhoNNy4bA1ToeILElN1F3FDwt0000K
            </div>
            <p class="token-hint">Click the code block to select it.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="container max-w-2xl text-center">
        <div class="cta-card">
          <h2 class="cta-title">Ready for a full deployment?</h2>
          <p class="cta-desc">
            Tested Onedata and ready to set it up for your institution or
            research group? Get in touch — we'll help you build a fully-fledged
            ecosystem for your use cases.
          </p>
          <a href="/contact" class="cta-button">
            Request a Demo <ArrowRight class="button-arrow" />
          </a>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

<script>
  // Select-all logic for the token
  const tokenBlock = document.getElementById("sandbox-token");
  if (tokenBlock) {
    tokenBlock.addEventListener("click", () => {
      const range = document.createRange();
      range.selectNodeContents(tokenBlock);
      const selection = window.getSelection();
      selection.removeAllRanges();
      selection.addRange(range);
    });
  }
</script>

<style>
  .quick-start-page {
    --accent: var(--od-accent, #e6341a);
    --bg-card: var(--od-bg-card, #ffffff);
    --bg-2: var(--od-bg-2, #f0ede8);
    --border: var(--od-border, rgba(0, 0, 0, 0.1));
    --text: var(--od-text, #111111);
    --text-muted: var(--od-text-muted, #555555);
    background-color: var(--od-bg);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .max-w-3xl {
    max-width: 48rem;
  }
  .max-w-4xl {
    max-width: 56rem;
  }
  .max-w-5xl {
    max-width: 64rem;
  }
  .max-w-2xl {
    max-width: 42rem;
  }

  /* Section Styles */
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: clamp(1.5rem, 5vw, 2rem);
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  .section-sub {
    color: var(--text-muted);
  }

  /* Concepts */
  .concepts-section {
    padding: 4rem 0;
  }

  .concepts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .concept-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 1.5rem;
    padding: 1.5rem;
    text-align: center;
    transition: transform 0.3s;
  }

  .concept-card:hover {
    transform: translateY(-4px);
  }

  .concept-icon-wrap {
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    background: var(--od-glow);
    border: 1px solid var(--od-glow-strong);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
  }

  .concept-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--accent);
  }

  .concept-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .concept-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Guide Section */
  .guide-section {
    padding: 4rem 0;
    background-color: var(--bg-2);
  }

  /* Token Section */
  .token-section {
    padding: 4rem 0;
    background-color: var(--bg-2);
  }

  .token-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 1.5rem;
    padding: 2rem;
    display: flex;
    gap: 1.5rem;
  }

  @media (max-width: 640px) {
    .token-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }

  .token-icon-wrap {
    width: 2.5rem;
    height: 2.5rem;
    background: var(--od-glow);
    border: 1px solid var(--od-glow-strong);
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .token-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--accent);
  }

  .token-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .token-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .token-code {
    background: var(--od-bg-input);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1rem;
    font-family: var(--font-family-mono);
    font-size: 0.75rem;
    color: var(--od-accent-3);
    word-break: break-all;
    cursor: pointer;
    user-select: all;
    margin-bottom: 0.5rem;
  }

  .token-hint {
    font-size: 0.75rem;
    color: var(--text-faint);
  }

  /* CTA Section */
  .cta-section {
    padding: 6rem 0;
  }

  .cta-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 2rem;
    padding: 3rem 2rem;
  }

  @media (min-width: 768px) {
    .cta-card {
      padding: 4rem;
    }
  }

  .cta-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .cta-desc {
    color: var(--text-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    background: linear-gradient(135deg, var(--accent), #ff6b4a);
    color: white;
    font-weight: 600;
    border-radius: 0.75rem;
    box-shadow: 0 8px 24px var(--od-glow-strong);
    transition:
      transform 0.2s,
      opacity 0.2s;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    opacity: 0.95;
    text-decoration: none;
  }

  .button-arrow {
    width: 1rem;
    height: 1rem;
  }
</style>
