---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import { getCollection, render } from "astro:content";
import fs from "node:fs";
import path from "node:path";
import yaml from "js-yaml";
import type { CollectionEntry } from "astro:content";
import ReleaseAssets from "../../../components/ReleaseAssets.tsx";

export type SidebarTree = SidebarNode[];
export type SidebarNode = {
  id: string;
  label: string;
  type: "file" | "dir" | "anchor" | "heading" | "link";
  href?: string;
  children?: SidebarTree;
};

// -- Sidebar builder for releases-docs content (version-independent) ----------

type ReleasesDocsEntry = CollectionEntry<"releases-docs">;
type ReleaseEntry = CollectionEntry<"releases">;

// -- getStaticPaths -----------------------------------------------------------

export async function getStaticPaths() {
  function getReleasesDocsPath(entry: ReleasesDocsEntry): string {
    if (!entry.filePath) throw new Error(`Entry ${entry.id} has no filePath`);
    return entry.filePath
      .replace(/\.mdx?$/, "")
      .replace(/^.*src\/content\/releases-docs\//, "");
  }

  async function buildSidebarTree(
    docs: ReleasesDocsEntry[],
    releases: ReleaseEntry[],
    currentRelPath: string = "",
  ): Promise<SidebarTree> {
    const sidebarTree: SidebarTree = [];
    const dirsMap: Map<string, ReleasesDocsEntry[]> = new Map();

    for (const doc of docs) {
      const docParts = getReleasesDocsPath(doc).split("/");
      const currentRelParts = currentRelPath ? currentRelPath.split("/") : [];

      if (docParts.length === currentRelParts.length + 1) {
        if (currentRelParts.every((p, i) => p === docParts[i])) {
          const part = docParts[docParts.length - 1];
          const isIndex = part === "index";
          const slugParts = isIndex ? docParts.slice(0, -1) : docParts;
          const hrefPath =
            slugParts.length > 0 ? `/${slugParts.join("/")}` : "";
          sidebarTree.push({
            id: part,
            type: "file",
            label: doc.data.title || part,
            href: `/docs/releases${hrefPath}`,
          });
        }
      } else if (docParts.length > currentRelParts.length + 1) {
        if (currentRelParts.every((p, i) => p === docParts[i])) {
          const dirName = docParts[currentRelParts.length];
          if (!dirsMap.has(dirName)) dirsMap.set(dirName, []);
          dirsMap.get(dirName)!.push(doc);
        }
      }
    }

    // Process subdirectories
    for (const [dirName, subDocs] of dirsMap) {
      const subRelPath = currentRelPath
        ? `${currentRelPath}/${dirName}`
        : dirName;
      sidebarTree.push({
        id: dirName,
        type: "dir",
        label: dirName,
        children: await buildSidebarTree(subDocs, [], subRelPath),
      });
    }

    // Apply -sidebar.yaml
    const configPath = path.join(
      process.cwd(),
      "src/content/releases-docs",
      currentRelPath,
      "-sidebar.yaml",
    );
    if (fs.existsSync(configPath)) {
      try {
        const config = yaml.load(fs.readFileSync(configPath, "utf8")) as any;
        if (config?.order && Array.isArray(config.order)) {
          sidebarTree.sort((a, b) => {
            const ia = config.order.indexOf(a.id);
            const ib = config.order.indexOf(b.id);
            if (ia !== -1 && ib !== -1) return ia - ib;
            if (ia !== -1) return -1;
            if (ib !== -1) return 1;
            return a.label.localeCompare(b.label);
          });
        }
      } catch {}
    } else {
      sidebarTree.sort((a, b) => a.label.localeCompare(b.label));
    }

    const sortedReleases = [...releases].sort(
      (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
    );

    // Append RELEASES section below regular items
    if (currentRelPath === "" && releases.length > 0) {
      sidebarTree.push({
        id: "__releases__",
        type: "heading",
        label: "RELEASES",
        children: sortedReleases.map((r) => ({
          id: r.id,
          type: "link" as const,
          label: r.data.version,
          // FIXME: support for dots inside versions
          href: `/docs/releases/${r.id}`,
        })),
      });
    }

    return sidebarTree;
  }

  const releasesDocsEntries = await getCollection("releases-docs");
  const releases = await getCollection("releases");

  const paths: any[] = [];

  // Build sidebar (same for all pages in /docs/releases/)
  const sidebarTree = await buildSidebarTree(releasesDocsEntries, releases);

  // 1. Pages from releases-docs content
  for (const entry of releasesDocsEntries) {
    const entryPath = getReleasesDocsPath(entry);
    const parts = entryPath.split("/");
    const last = parts[parts.length - 1];
    const slugParts = last === "index" ? parts.slice(0, -1) : parts;
    const innerSlug = slugParts.length > 0 ? slugParts.join("/") : undefined;

    // Check for redirect from -sidebar.yaml
    const configPath = path.join(
      process.cwd(),
      "src/content/releases-docs",
      "-sidebar.yaml",
    );
    let redirectTarget: string | undefined;
    if (fs.existsSync(configPath)) {
      try {
        const config = yaml.load(fs.readFileSync(configPath, "utf8")) as any;
        if (config?.redirect && !innerSlug) {
          redirectTarget = config.redirect;
        }
      } catch {}
    }

    paths.push({
      params: { slug: innerSlug },
      props: {
        entry,
        sidebarTree,
        isRelease: false,
        isRedirect: !!redirectTarget,
        redirectTarget,
      },
    });
  }

  // 2. Directory redirect: /docs/releases → /docs/releases/compatibility
  const configPath = path.join(
    process.cwd(),
    "src/content/releases-docs",
    "-sidebar.yaml",
  );
  let topRedirect: string | undefined;
  if (fs.existsSync(configPath)) {
    try {
      const config = yaml.load(fs.readFileSync(configPath, "utf8")) as any;
      if (config?.redirect) topRedirect = config.redirect;
    } catch {}
  }
  if (topRedirect) {
    paths.push({
      params: { slug: undefined },
      props: {
        entry: { data: { title: "Redirecting..." } },
        sidebarTree,
        isRelease: false,
        isRedirect: true,
        redirectTarget: topRedirect,
      },
    });
  }

  // 3. Pages from releases collection
  for (const release of releases) {
    paths.push({
      params: { slug: release.id },
      props: { release, sidebarTree, isRelease: true, isRedirect: false },
    });
  }

  return paths;
}

// -- Page props & render -------------------------------------------------------

type Props =
  | {
      isRelease: false;
      isRedirect: true;
      redirectTarget: string;
      entry: any;
      sidebarTree: SidebarTree;
    }
  | {
      isRelease: false;
      isRedirect: false;
      entry: CollectionEntry<"releases-docs">;
      sidebarTree: SidebarTree;
    }
  | {
      isRelease: true;
      isRedirect: false;
      release: CollectionEntry<"releases">;
      sidebarTree: SidebarTree;
    };

const props = Astro.props as Props;
const { sidebarTree } = props;

const redirectUrl = props.isRedirect
  ? props.redirectTarget!.startsWith("/")
    ? props.redirectTarget
    : `/docs/releases/${props.redirectTarget}`
  : null;

const Content =
  !props.isRedirect && !props.isRelease
    ? (await render(props.entry as CollectionEntry<"releases-docs">)).Content
    : props.isRelease
      ? (await render(props.release)).Content
      : null;

const title = props.isRelease
  ? props.release.data.title
  : !props.isRedirect
    ? props.entry.data.title
    : "Redirecting…";

const release = props.isRelease ? props.release : null;
---

{
  props.isRedirect ? (
    <html>
      <head>
        <meta http-equiv="refresh" content={`0;url=${redirectUrl}`} />
        <script is:inline define:vars={{ redirectUrl }}>
          window.location.href = redirectUrl;
        </script>
      </head>
      <body>
        <p>
          Redirecting to <a href={redirectUrl}>{redirectUrl}</a>...
        </p>
      </body>
    </html>
  ) : (
    <DocsLayout
      title={`${title} | Onedata Releases`}
      version="25"
      availableVersions={["25"]}
      activeChapter="releases"
      sidebarNodes={sidebarTree}
      showVersionSelector={false}
    >
      {release ? (
        <div class="release-page">
          <div class="release-header mb-6 flex flex-wrap items-start justify-between gap-4">
            <h1 class="release-title od-text m-0 text-2xl font-bold">
              Release {release.data.version}
            </h1>
          </div>

          <ReleaseAssets version={release.data.version} client:visible />

          <div class="prose">
            {release.data.highlights && release.data.highlights.length > 0 && (
              <section class="release-section">
                <h2>Highlights</h2>
                <ul>
                  {release.data.highlights.map(
                    ({ title, shortDescription }) => (
                      <li>
                        <strong>{title}</strong> — {shortDescription}
                      </li>
                    ),
                  )}
                </ul>
              </section>
            )}

            {release.data.upgradeNotes &&
              release.data.upgradeNotes.length > 0 && (
                <section class="release-section">
                  <h2>Upgrade Notes</h2>
                  <ul class="release-bullets">
                    {release.data.upgradeNotes.map((n) => (
                      <li>{n}</li>
                    ))}
                  </ul>
                </section>
              )}

            <section class="release-section">
              <h2>Full Changelog</h2>
              <ul class="release-bullets">
                {release.data.changelog.map((changelogEntry) => (
                  <li>
                    <strong>{changelogEntry.issue}</strong>{" "}
                    <em>({changelogEntry.products})</em>{" "}
                    {changelogEntry.description}
                  </li>
                ))}
              </ul>
            </section>
          </div>
        </div>
      ) : (
        <div class="prose">{Content && <Content />}</div>
      )}
    </DocsLayout>
  )
}

<style>
  .release-title {
    margin-bottom: 0;
  }

  .release-page {
    padding-bottom: 4rem;
  }

  .release-desc {
    font-size: 1.05rem;
    color: var(--od-text);
    opacity: 0.8;
    margin-bottom: 1.5rem;
    line-height: 1.6;
    max-width: 680px;
  }

  .release-action-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .release-section {
    margin-bottom: 2.5rem;
  }

  .release-bullets {
    padding-left: 1.5rem;
    margin: 0;
  }

  .release-bullets li {
    margin-bottom: 0.45rem;
    line-height: 1.6;
    color: var(--od-text);
  }
</style>
