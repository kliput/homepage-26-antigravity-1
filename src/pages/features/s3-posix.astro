  benefits={[
    "Single dataset accessible via both S3 API and POSIX filesystem",
    "No data duplication or sync complexity",
    "Ideal for cloud-native pipelines and HPC workloads simultaneously",
    "Leverage existing tools and workflows without migration",
  ]}
/>
