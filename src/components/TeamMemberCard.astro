---
interface Props {
  member: {
    name: string;
    role: string;
    affiliation: string;
    bio: string;
    avatar: string;
  };
}

const { member } = Astro.props;
const firstName = member.name.split(" ")[0];
---

<div class="team-card">
  <img
    src={member.avatar}
    alt={member.name}
    class="team-avatar"
  />
  <h3 class="team-name">{member.name}</h3>
  <p class="team-role">{member.role}</p>
  <p class="team-affiliation">{member.affiliation}</p>
  <p class="team-bio">{member.bio}</p>
  <a
    href={`mailto:info@onedata.org?subject=Message for ${member.name}`}
    class="team-contact-btn no-external-icon"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
      <polyline points="22,6 12,13 2,6"></polyline>
    </svg>
    Contact {firstName}
  </a>
</div>

<style>
  .team-card {
    background: var(--od-bg-card);
    border: 1px solid var(--od-border);
    border-radius: 1rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: box-shadow 0.2s;
  }

  .team-card:hover {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }

  .team-avatar {
    width: 6rem;
    height: 6rem;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1rem;
    border: 2px solid var(--od-accent);
    opacity: 0.95;
  }

  .team-name {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--od-text);
    margin-bottom: 0.25rem;
  }

  .team-role {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--od-accent);
    margin-bottom: 0.25rem;
  }

  .team-affiliation {
    font-size: 0.75rem;
    color: var(--od-text-faint);
    margin-bottom: 0.75rem;
  }

  .team-bio {
    font-size: 0.875rem;
    color: var(--od-text-muted);
    line-height: 1.6;
    margin-bottom: 1.25rem;
    flex: 1;
  }

  .team-contact-btn {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--od-accent);
    border: 1px solid var(--od-accent);
    border-radius: 9999px;
    padding: 0.375rem 1rem;
    transition: background-color 0.2s;
    text-decoration: none;
  }

  .team-contact-btn:hover {
    background-color: var(--od-glow);
    text-decoration: none;
  }
</style>
