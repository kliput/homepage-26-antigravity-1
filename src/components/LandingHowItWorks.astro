---
const steps = [
  {
    number: "01",
    title: "Connect your storage",
    description:
      "Register any storage backend — cloud buckets, HPC storage, institutional repositories — via simple configuration. No data movement required.",
  },
  {
    number: "02",
    title: "Define your data spaces",
    description:
      "Create virtual Spaces that aggregate multiple storage resources. Set replication, caching, and access policies per dataset.",
  },
  {
    number: "03",
    title: "Access from anywhere",
    description:
      "Use POSIX, REST API, CDMI, or our Python/R SDKs. Your AI pipeline sees a single filesystem regardless of where data lives.",
  },
  {
    number: "04",
    title: "Collaborate & govern",
    description:
      "Invite institutions, share datasets, and track provenance. Full audit logs and fine-grained permissions across the federation.",
  },
];
---

<section id="how-it-works" class="how-it-works-section">
  <div class="container max-w-5xl">
    <div class="mb-16 text-center">
      <div class="how-pill">HOW IT WORKS</div>
      <h2 class="how-title">
        From setup to pipeline <span class="gradient-text">in minutes</span>
      </h2>
      <p class="how-subtitle">
        Onedata is designed for rapid deployment. Connect your existing
        infrastructure without disrupting ongoing workflows.
      </p>
    </div>

    <div class="timeline-container">
      <div class="timeline-center-line"></div>

      <div class="timeline-steps">
        {
          steps.map((step, i) => {
            const isEven = i % 2 !== 0;
            return (
              <div class={`timeline-step ${isEven ? "step-reverse" : ""}`}>
                <div class={`step-content-box ${isEven ? "text-right" : ""}`}>
                  <div class="step-number">{step.number}</div>
                  <h3 class="step-title">{step.title}</h3>
                  <p class="step-desc">{step.description}</p>
                </div>

                <div class="step-center-dot" />

                <div class="step-empty-box" />
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<style>
  .how-it-works-section {
    padding: 6rem 1rem;
    background-color: var(--od-bg-2);
  }

  .max-w-5xl {
    max-width: 64rem;
    margin: 0 auto;
  }

  .text-center {
    text-align: center;
  }
  .mb-16 {
    margin-bottom: 4rem;
  }

  .how-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--border);
    color: var(--od-text);
    opacity: 0.7;
    font-size: 0.75rem;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    margin-bottom: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .how-title {
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--od-text);
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .how-title {
      font-size: 3rem;
    }
  }

  .gradient-text {
    background: linear-gradient(to right, var(--primary, #e11d48), #f43f5e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  html[data-theme="dark"] .gradient-text {
    background: linear-gradient(to right, #fb7185, #fda4af);
    -webkit-background-clip: text;
  }

  .how-subtitle {
    color: var(--od-text);
    opacity: 0.7;
    max-width: 36rem;
    margin: 0 auto;
    line-height: 1.6;
    font-size: 1.125rem;
  }

  .timeline-container {
    position: relative;
    padding: 2rem 0;
  }

  .timeline-center-line {
    display: none;
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    transform: translateX(-50%);
    background: linear-gradient(
      to bottom,
      var(--primary, #e11d48),
      transparent
    );
    opacity: 0.3;
  }

  @media (min-width: 768px) {
    .timeline-center-line {
      display: block;
    }
  }

  .timeline-steps {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .timeline-step {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .step-center-dot {
    display: none;
  }
  .step-empty-box {
    display: none;
  }

  @media (min-width: 768px) {
    .timeline-step {
      flex-direction: row;
      align-items: center;
      gap: 1.5rem;
    }

    .timeline-step.step-reverse {
      flex-direction: row-reverse;
    }

    .step-content-box {
      flex: 1;
    }

    .text-right {
      text-align: right;
    }

    .step-center-dot {
      display: block;
      position: relative;
      z-index: 10;
      width: 1rem;
      height: 1rem;
      border-radius: 50%;
      background-color: var(--primary, #e11d48);
      flex-shrink: 0;
      box-shadow: 0 0 0 4px rgba(225, 29, 72, 0.2);
    }

    html[data-theme="dark"] .step-center-dot {
      background-color: #fb7185;
      box-shadow: 0 0 0 4px rgba(251, 113, 133, 0.2);
    }

    .step-empty-box {
      display: block;
      flex: 1;
    }
  }

  .step-number {
    font-family: var(--font-family-mono);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--primary, #e11d48);
    margin-bottom: 0.5rem;
  }

  html[data-theme="dark"] .step-number {
    color: #fb7185;
  }

  .step-title {
    color: var(--od-text);
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .step-desc {
    color: var(--od-text);
    opacity: 0.7;
    font-size: 0.875rem;
    line-height: 1.7;
    max-width: 24rem;
  }

  @media (min-width: 768px) {
    .step-content-box.text-right .step-desc {
      margin-left: auto;
    }
  }
</style>
