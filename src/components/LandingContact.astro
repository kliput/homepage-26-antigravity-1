---
import { Microscope, Cpu, Globe, CheckCircle } from "@lucide/astro";

const highlights = [
  {
    icon: Microscope,
    title: "Tailored to your use case",
    description: "Tell us about your research domain — genomics, climate, HPC, AI — and we'll focus the demo on workflows that matter to you.",
  },
  {
    icon: Cpu,
    title: "Live infrastructure walkthrough",
    description: "See a real Onedata deployment: federated storage, data spaces, provider setup, and access control in action.",
  },
  {
    icon: Globe,
    title: "Integration assessment",
    description: "We'll evaluate how Onedata fits your existing storage (S3, POSIX, Ceph, NFS) and compute environments.",
  },
];

const perks = [
  "30-minute focused session",
  "Zoom / Meet video call",
  "Weekdays · CET timezone",
  "Dedicated onboarding support during pilot",
];
---

<section id="contact" class="contact-section">
  <div class="container max-w-5xl">
    <div class="text-center mb-14">
      <div class="section-pill">REQUEST A DEMO</div>
      <h2 class="section-title">
        Get a demo tailored to <span class="gradient-text">your organization</span>
      </h2>
      <p class="section-subtitle">
        Onedata is a complex platform. That's why every demo is scoped to your specific infrastructure,
        research domain, and data challenges — so you leave with a clear path to getting started.
      </p>
    </div>

    <div class="highlights-grid">
      {highlights.map((item) => {
        const Icon = item.icon;
        return (
          <div class="highlight-card">
            <div class="highlight-icon-wrap">
              <Icon class="highlight-icon" />
            </div>
            <h3 class="highlight-title">{item.title}</h3>
            <p class="highlight-desc">{item.description}</p>
          </div>
        );
      })}
    </div>

    <div class="cta-card">
      <div class="perks-list">
        <p class="perks-label">What to expect</p>
        <ul class="perks">
          {perks.map((perk) => (
            <li class="perk-item">
              <CheckCircle class="perk-icon" />
              {perk}
            </li>
          ))}
        </ul>
      </div>
      <a href="/contact" class="book-btn">
        Book your demo
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: 6rem 1rem;
    background-color: var(--color-bg-2, var(--color-bg));
  }

  .max-w-5xl {
    max-width: 64rem;
    margin: 0 auto;
  }

  .text-center { text-align: center; }
  .mb-14 { margin-bottom: 3.5rem; }

  .section-pill {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    opacity: 0.7;
    font-size: 0.75rem;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    margin-bottom: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .section-title {
    font-size: clamp(1.875rem, 5vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--color-text);
    line-height: 1.2;
  }

  .gradient-text {
    background: linear-gradient(to right, var(--color-primary, #e11d48), #f43f5e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  html[data-theme="dark"] .gradient-text {
    background: linear-gradient(to right, #fb7185, #fda4af);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .section-subtitle {
    color: var(--color-text);
    opacity: 0.7;
    max-width: 40rem;
    margin: 0 auto;
    line-height: 1.6;
    font-size: 1rem;
  }

  .highlights-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
    margin-bottom: 2.5rem;
  }

  @media (min-width: 768px) {
    .highlights-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .highlight-card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.5rem;
  }

  .highlight-icon-wrap {
    display: inline-flex;
    padding: 0.625rem;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, var(--color-primary, #e11d48), #be123c);
    margin-bottom: 1rem;
  }

  .highlight-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: white;
  }

  .highlight-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .highlight-desc {
    font-size: 0.875rem;
    color: var(--color-text);
    opacity: 0.7;
    line-height: 1.6;
  }

  .cta-card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }

  @media (min-width: 768px) {
    .cta-card {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .perks-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text);
    opacity: 0.5;
    margin-bottom: 0.75rem;
  }

  .perks {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem 1.5rem;
  }

  .perk-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text);
    opacity: 0.8;
  }

  .perk-icon {
    width: 1rem;
    height: 1rem;
    color: var(--color-primary, #e11d48);
    flex-shrink: 0;
  }

  .book-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    background: linear-gradient(135deg, var(--color-primary, #e11d48), #be123c);
    color: white;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: 0.75rem;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s, transform 0.2s;
    flex-shrink: 0;
  }

  .book-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
    text-decoration: none;
  }
</style>
