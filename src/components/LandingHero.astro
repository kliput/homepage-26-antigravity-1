---
import { ArrowRight, ChevronDown } from "@lucide/astro";
import PulseDot from "./PulseDot.astro";
---

<section class="hero-section">
  <!-- Animated background grid -->
  <div class="hero-grid-bg"></div>

  <!-- Glow orbs -->
  <div class="hero-glow-orb orb-center"></div>

  <!-- Hero content — centered -->
  <div class="hero-content">
    <div
      class="hero-pill mb-6 inline-flex items-center gap-2 rounded-full border px-4 py-2 text-xs"
    >
      <PulseDot />
      Open-source &middot; Trusted by 100+ research institutions worldwide
    </div>

    <h1 class="hero-title">
      Data Management Platform for
      <span class="gradient-text">Distributed AI Pipelines</span>
      and Hybrid Clouds
    </h1>

    <p class="hero-subtitle">
      Onedata unifies your storage resources across HPC clusters, cloud
      providers, and institutional repositories — giving researchers a single,
      high-performance data layer for any AI pipeline.
    </p>

    <div class="hero-actions">
      <a href="/contact" class="btn-primary">
        Request a Demo <ArrowRight class="btn-icon" />
      </a>
      <a
        href="https://github.com/onedata"
        target="_blank"
        rel="noreferrer"
        class="btn-secondary"
      >
        <svg viewBox="0 0 24 24" class="btn-icon-gh" fill="currentColor">
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
          ></path>
        </svg>
        View on GitHub
      </a>
    </div>

    <a href="/docs#ver-25-0" class="release-pill">
      <PulseDot />
      Latest release — v25.0
      <svg
        class="release-arrow"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
        ></path>
      </svg>
    </a>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator">
    <ChevronDown class="scroll-icon" />
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: calc(100vh - var(--site-header-height));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 4rem 1.5rem;
    background-color: var(--od-bg);
    text-align: center;
  }

  /* === Background grid === */
  .hero-grid-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image:
      linear-gradient(var(--od-glow) 1px, transparent 1px),
      linear-gradient(90deg, var(--od-glow) 1px, transparent 1px);
    background-size: 60px 60px;
    -webkit-mask-image: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      black 30%,
      transparent 100%
    );
    mask-image: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      black 30%,
      transparent 100%
    );
  }

  html[data-theme="dark"] .hero-grid-bg {
    background-image:
      linear-gradient(to right, rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
  }

  /* === Glow orb — perfectly centered === */
  .hero-glow-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }

  .orb-center {
    width: 1000px;
    height: 1000px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, var(--primary, #e11d48), transparent);
    opacity: 0.1;
    filter: blur(60px);
  }

  html[data-theme="dark"] .orb-center {
    opacity: 0.12;
  }

  /* === Content === */
  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 56rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  /* === Pill === */
  .hero-pill {
    border: 1px solid var(--od-glow-strong);
    color: var(--od-accent-3);
    background: var(--od-glow);
  }

  /* === Title === */
  .hero-title {
    font-size: clamp(2.25rem, 6vw, 4.25rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--od-text);
    margin: 0;
  }

  .gradient-text {
    background: linear-gradient(to right, var(--primary, #e11d48), #f43f5e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  html[data-theme="dark"] .gradient-text {
    background: linear-gradient(to right, #fb7185, #fda4af);
    -webkit-background-clip: text;
    background-clip: text;
  }

  /* === Subtitle === */
  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: var(--od-text);
    opacity: 0.7;
    max-width: 38rem;
    line-height: 1.7;
    margin: 0;
  }

  /* === Action buttons === */
  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  @media (min-width: 480px) {
    .hero-actions {
      flex-direction: row;
      justify-content: center;
    }
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 2rem;
    background: linear-gradient(135deg, var(--primary, #e11d48), #be123c);
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 0.75rem;
    text-decoration: none;
    box-shadow: 0 10px 30px -6px rgba(225, 29, 72, 0.4);
    transition:
      opacity 0.2s,
      transform 0.2s,
      box-shadow 0.2s;
    white-space: nowrap;
  }

  .btn-primary:hover {
    opacity: 0.92;
    transform: translateY(-2px);
    box-shadow: 0 14px 36px -6px rgba(225, 29, 72, 0.5);
    text-decoration: none;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    color: var(--od-text);
    font-weight: 500;
    font-size: 0.9375rem;
    border-radius: 0.75rem;
    text-decoration: none;
    border: 1px solid var(--border);
    transition:
      border-color 0.2s,
      background-color 0.2s,
      color 0.2s;
    white-space: nowrap;
  }

  .btn-secondary:hover {
    border-color: var(--od-text);
    text-decoration: none;
  }

  .btn-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .btn-icon-gh {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  /* === Release pill === */
  .release-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4375rem 1.125rem;
    border-radius: 9999px;
    border: 1px solid
      color-mix(in srgb, var(--primary, #e11d48) 40%, transparent);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--primary, #e11d48);
    text-decoration: none;
    transition: background-color 0.2s;
  }

  .release-pill:hover {
    background-color: color-mix(
      in srgb,
      var(--primary, #e11d48) 8%,
      transparent
    );
    text-decoration: none;
  }

  .release-arrow {
    width: 0.875rem;
    height: 0.875rem;
    opacity: 0.7;
  }

  /* === Scroll indicator === */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    animation: bounce 2s ease-in-out infinite;
  }

  .scroll-icon {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--od-text);
    opacity: 0.4;
  }

  @keyframes bounce {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(8px);
    }
  }
</style>
