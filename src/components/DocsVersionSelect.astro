---
const {
  availableVersions,
  version,
  pathPrefix,
  pathSuffix,
  selectorId,
  stableVersion,
  latestVersion,
} = Astro.props;

function isVersionSelected(v: string) {
  if (version === "stable") {
    return v === stableVersion;
  }
  if (version === "latest") {
    return v === latestVersion;
  }
  return v === version;
}

const className = Astro.props.className;
---

<div class={"version-select-wrap" + (className ? " " + className : "")}>
  <label for={selectorId} class="version-label">Version:</label>
  <select
    id={selectorId}
    class="version-select"
    onchange="window.location.href=this.value"
  >
    {
      availableVersions.map((v: string) => (
        <option
          value={`${pathPrefix}/${v}/${pathSuffix}`}
          selected={isVersionSelected(v)}
        >
          {v}{" "}
          {stableVersion && v === stableVersion
            ? "(stable)"
            : latestVersion && v === latestVersion
              ? "(latest)"
              : ""}
        </option>
      ))
    }
  </select>
</div>

<style>
  .version-select-wrap {
    align-items: center;
    gap: 0.5rem;
  }

  .version-label {
    font-size: 0.75rem;
    color: var(--od-text-muted);
  }

  .version-select-wrap.label-hidden .version-label {
    display: none;
  }

  .version-select {
    /* Base styles are now global */
    font-size: 0.875rem; /* Specific override if needed, or just let it be global */
  }
</style>
