---
import MainLayout from "../layouts/MainLayout.astro";
import LandingContact from "../components/LandingContact.astro";

export interface UseCase {
  label: string;
  icon: any;
  title: string;
  tagline: string;
  description: string;
  image: string;
  tags: string[];
  challenges: string[];
  capabilities: { emoji: string; title: string; detail: string }[];
  relatedCases: { href: string; label: string; title: string }[];
}

interface Props {
  useCase: UseCase;
}

const { useCase } = Astro.props;
const { label, icon: Icon, title, tagline, description, image, tags, challenges, capabilities, relatedCases } = useCase;
---

<MainLayout title={`${label} — Onedata`} description={tagline}>
  <!-- Header hero background -->
  <div class="page-hero-wrap">
    <div class="page-hero-grid"></div>
    <div class="page-hero-glow"></div>

    <div class="container max-w-5xl">
      <a href="/" class="back-link">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Back to home
      </a>

      <div class="hero-badge">
        <Icon class="badge-icon" />
        {label}
      </div>
      <h1 class="hero-title">{title}</h1>
      <p class="hero-tagline">{tagline}</p>
      <div class="tags-row">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </div>
  </div>

  <!-- Hero image -->
  <div class="container max-w-5xl">
    <div class="hero-image-wrap">
      <img src={image} alt={label} class="hero-image" />
    </div>
  </div>

  <!-- Content -->
  <div class="container max-w-5xl content-section">
    <div class="overview-grid">
      <div>
        <h2 class="content-heading">Overview</h2>
        <p class="content-body">{description}</p>
      </div>
      <div>
        <h2 class="content-heading">Key Challenges Solved</h2>
        <ul class="challenges-list">
          {challenges.map((c) => (
            <li class="challenge-item">
              <span class="challenge-dot-wrap"><span class="challenge-dot"></span></span>
              {c}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Capabilities -->
    <div class="capabilities-section">
      <h2 class="content-heading text-center">Onedata capabilities for this use case</h2>
      <div class="capabilities-grid">
        {capabilities.map((cap) => (
          <div class="cap-card">
            <div class="cap-emoji">{cap.emoji}</div>
            <h3 class="cap-title">{cap.title}</h3>
            <p class="cap-detail">{cap.detail}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Related -->
    {relatedCases?.length > 0 && (
      <div class="related-section">
        <h2 class="content-heading">Related use cases</h2>
        <div class="related-grid">
          {relatedCases.map((rc) => (
            <a href={rc.href} class="related-card">
              <div>
                <div class="related-label">{rc.label}</div>
                <div class="related-title">{rc.title}</div>
              </div>
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="related-arrow">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>

  <LandingContact />
</MainLayout>

<style>
  /* === Hero header === */
  .page-hero-wrap {
    position: relative;
    padding: 5rem 1rem 6rem;
    background-color: var(--color-bg-2, var(--color-bg));
    overflow: hidden;
  }

  .page-hero-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(var(--od-glow, rgba(0,0,0,0.04)) 1px, transparent 1px),
      linear-gradient(90deg, var(--od-glow, rgba(0,0,0,0.04)) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  html[data-theme="dark"] .page-hero-grid {
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
  }

  .page-hero-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(circle, var(--color-primary, #e11d48), transparent 70%);
    opacity: 0.07;
    filter: blur(80px);
    pointer-events: none;
  }

  .max-w-5xl {
    max-width: 64rem;
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text);
    opacity: 0.5;
    font-size: 0.875rem;
    text-decoration: none;
    margin-bottom: 2rem;
    transition: opacity 0.2s;
    position: relative;
    z-index: 1;
  }

  .back-link:hover {
    opacity: 0.9;
    text-decoration: none;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--color-primary, #e11d48) 40%, transparent);
    background-color: color-mix(in srgb, var(--color-primary, #e11d48) 10%, transparent);
    color: var(--color-primary, #e11d48);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    margin-bottom: 1rem;
    position: relative;
    z-index: 1;
  }

  .badge-icon {
    width: 0.875rem;
    height: 0.875rem;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: var(--color-text);
    position: relative;
    z-index: 1;
  }

  .hero-tagline {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: var(--color-text);
    opacity: 0.7;
    max-width: 40rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .tags-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    position: relative;
    z-index: 1;
  }

  .tag {
    font-size: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    padding: 0.25rem 0.75rem;
    color: var(--color-text);
    opacity: 0.6;
  }

  /* === Hero image === */
  .hero-image-wrap {
    margin-top: -3rem;
    margin-bottom: 5rem;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    overflow: hidden;
    height: 16rem;
  }

  @media (min-width: 768px) {
    .hero-image-wrap { height: 24rem; }
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.75;
  }

  /* === Content === */
  .content-section {
    padding-bottom: 6rem;
  }

  .overview-grid {
    display: grid;
    gap: 4rem;
    margin-bottom: 5rem;
  }

  @media (min-width: 768px) {
    .overview-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .content-heading {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .text-center { text-align: center; }

  .content-body {
    color: var(--color-text);
    opacity: 0.75;
    line-height: 1.75;
  }

  .challenges-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .challenge-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9375rem;
    color: var(--color-text);
    opacity: 0.75;
  }

  .challenge-dot-wrap {
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-primary, #e11d48) 20%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 0.2rem;
  }

  .challenge-dot {
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 50%;
    background: var(--color-primary, #e11d48);
  }

  /* === Capabilities === */
  .capabilities-section {
    margin-bottom: 5rem;
  }

  .capabilities-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
    margin-top: 2rem;
  }

  @media (min-width: 640px) {
    .capabilities-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .capabilities-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .cap-card {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem;
    background-color: var(--color-bg);
  }

  .cap-emoji {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .cap-title {
    font-size: 0.9375rem;
    font-weight: 600;
    margin-bottom: 0.375rem;
    color: var(--color-text);
  }

  .cap-detail {
    font-size: 0.8125rem;
    color: var(--color-text);
    opacity: 0.6;
    line-height: 1.6;
  }

  /* === Related === */
  .related-section {
    margin-bottom: 2rem;
  }

  .related-grid {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 768px) {
    .related-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .related-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem;
    background-color: var(--color-bg);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .related-card:hover {
    border-color: var(--color-primary, #e11d48);
    text-decoration: none;
  }

  .related-label {
    font-size: 0.75rem;
    color: var(--color-primary, #e11d48);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .related-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .related-arrow {
    color: var(--color-text);
    opacity: 0.4;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .related-card:hover .related-arrow {
    opacity: 0.9;
  }
</style>
