</footer>

<style>
  .site-footer {
    background-color: var(--od-bg);
    border-top: 1px solid var(--border);
    padding: 4rem 0 2rem;
    margin-top: auto;
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .footer-content {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-brand {
    max-width: 300px;
  }

  .copyright {
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--od-text);
    opacity: 0.7;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .footer-links {
      gap: 4rem;
    }
  }

  .footer-heading {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--od-text);
    margin-bottom: 1.25rem;
    opacity: 0.9;
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-list a {
    color: var(--od-text);
    opacity: 0.8;
    font-size: 0.95rem;
    transition:
      color 0.2s,
      opacity 0.2s;
  }

  .footer-list a:hover {
    color: var(--primary);
    opacity: 1;
    text-decoration: none;
  }
</style>

<style is:global>
  .footer-brand .onedata-logo {
    width: 120px;
    height: 21px;
  }
</style>
