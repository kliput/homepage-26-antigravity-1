      <div class="footer-group">
        <h3 class="footer-heading">RESOURCES</h3>
        <ul class="footer-list">
          <li><a href="/quick-start">Quick Start</a></li>
          <li><a href="/docs">Docs</a></li>
          <li><a href="/api">API</a></li>
          <li><a href="/blog">Blog</a></li>
