<style>
  :root {
    --header-text-color: var(--od-text-muted);
  }

  .site-header {
    height: var(--site-header-height);
    display: flex;
    align-items: center;
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1.25rem 3rem;
  }

  .main-nav {
    display: none;
  }

  @media (min-width: 768px) {
    .main-nav {
      display: block;
    }
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: 2rem;
    align-items: center;
    margin: 0;
    padding: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    color: var(--header-text-color);
    font-size: 0.875rem; /* text-sm */
    font-weight: 400;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--od-text);
    text-decoration: none;
  }

  .chevron {
    width: 12px;
    height: 12px;
    transition: transform 0.2s;
  }

  .has-dropdown:hover .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .has-dropdown:hover .chevron {
    transform: rotate(180deg);
  }

  .dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--od-bg-card);
    border: 1px solid var(--od-border);
    border-radius: 0.75rem; /* rounded-xl */
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); /* shadow-2xl */
    min-width: 220px;
    padding: 0;
    list-style: none;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition:
      opacity 0.2s,
      visibility 0.2s,
      transform 0.2s;
    overflow: hidden;
  }

  .dropdown a {
    display: block;
    padding: 1rem;
    color: var(--header-text-color);
    font-size: 0.875rem;
    border-bottom: 1px solid var(--od-border);
  }

  .dropdown li:last-child a {
    border-bottom: none;
  }

  .dropdown a:hover {
    background: var(--od-bg-2);
    color: var(--od-text);
    text-decoration: none;
  }

  /* === Rich dropdown === */
  .rich-dropdown {
    min-width: unset;
    padding: 0.5rem;
  }

  .features-dropdown {
    width: 560px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.125rem;
  }

  .use-cases-dropdown {
    width: 380px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.125rem;
  }

  .rich-item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    padding: 0.75rem;
    border-radius: 0.5rem;
    border-bottom: none !important;
    color: var(--header-text-color);
    text-decoration: none;
    transition: background-color 0.15s;
  }

  .rich-item:hover {
    background: var(--od-bg-2);
    color: var(--od-text);
    text-decoration: none;
  }

  .rich-icon {
    display: inline-flex;
    padding: 0.375rem;
    border-radius: 0.375rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .rich-text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .rich-title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--od-text, var(--od-text));
    line-height: 1.3;
  }

  .rich-desc {
    font-size: 0.75rem;
    color: var(--header-text-color);
    opacity: 0.85;
    line-height: 1.3;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem; /* gap-3 */
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 0.75rem; /* gap-3 */
  }

  .version-badge {
    display: none;
  }

  @media (min-width: 768px) {
    .version-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      padding: 0.25rem 0.75rem; /* px-3 py-1 */
      border-radius: 9999px; /* rounded-full */
      border: 1px solid var(--od-border);
      font-size: 0.75rem; /* text-xs */
      font-weight: 600; /* font-semibold */
      color: var(--od-accent);
      white-space: nowrap;
      transition: border-color 0.2s;
    }

    .version-badge:hover {
      border-color: var(--od-accent);
      text-decoration: none;
    }
  }

  .social-link {
    color: var(--header-text-color);
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .social-link:hover {
    color: var(--od-text);
  }

  .theme-toggle {
    background: none;
    border: none;
    color: var(--header-text-color);
    cursor: pointer;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      background-color 0.2s,
      color 0.2s;
  }

  .theme-toggle:hover {
    background-color: var(--od-bg-2);
    color: var(--primary);
  }

  /* Theme toggle SVG display logic */
  html[data-theme="light"] .moon-icon {
    display: block;
  }
  html[data-theme="light"] .sun-icon {
    display: none;
  }
  html[data-theme="dark"] .moon-icon {
    display: none;
  }
  html[data-theme="dark"] .sun-icon {
    display: block;
  }

  .menu-toggle {
    display: block;
    background: none;
    border: none;
    color: var(--header-text-color);
    cursor: pointer;
  }
  @media (min-width: 768px) {
    .menu-toggle {
      display: none;
    }
  }
</style>

<script>
  // Theme toggle script
  const themeToggleInfo = document.getElementById("theme-toggle");

  const handleToggleClick = () => {
    const element = document.documentElement;
    element.dataset.theme = element.dataset.theme === "dark" ? "light" : "dark";

    const isDark = element.dataset.theme === "dark";
    localStorage.setItem("theme", isDark ? "dark" : "light");
  };

  themeToggleInfo?.addEventListener("click", handleToggleClick);
</script>
