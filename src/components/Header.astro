---
import { Moon, Sun } from "lucide-astro";
import GitHub from "./icons/GitHub.tsx";
import Logo from "./Logo.astro";
import {
  getLatestReleaseSlug,
  getLatestReleaseVersion,
} from "../utils/releases";
import { MobileMenu } from "./MobileMenu.tsx";

const { pathname } = Astro.url;

const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(href + "/");
};

const latestReleaseString = `v${await getLatestReleaseVersion()}`;
const latestReleaseSlug = `/docs/releases/${await getLatestReleaseSlug()}`;

// Header component
---

<script>
  function highlightHowItWorks() {
    const hash = window.location.hash;
    if (hash === "#how-it-works") {
      const navLink = document.querySelector(".nav-link");
      navLink?.classList.add("active");
    }
  }
  highlightHowItWorks();
  window.addEventListener("hashchange", highlightHowItWorks);
</script>

