---
// Header component
---

<header class="site-header">
  <div class="container header-content">
    <div class="logo">
      <a href="/">
        <span class="logo-text">ONEDATA</span>
      </a>
    </div>

    <nav class="main-nav">
      <ul class="nav-list">
        <li class="nav-item has-dropdown">
          <span class="nav-link"
            >Features <svg
              class="chevron"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><polyline points="6 9 12 15 18 9"></polyline></svg
            ></span
          >
          <ul class="dropdown">
            <li>
              <a href="/features/unified-virtual-filesystem">
                Unified Virtual Filesystem
              </a>
            </li>
            <li>
              <a href="/features/hybrid-cloud-ready">Hybrid Cloud Ready</a>
            </li>
          </ul>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/how-it-works">How it works</a>
        </li>
        <li class="nav-item has-dropdown">
          <span class="nav-link"
            >Use cases <svg
              class="chevron"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><polyline points="6 9 12 15 18 9"></polyline></svg
            ></span
          >
          <ul class="dropdown">
            <li><a href="/use-cases/ai-ml-research">AI / ML Research</a></li>
            <li><a href="/use-cases/life-sciences">Life Sciences</a></li>
          </ul>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/quick-start">Quick Start</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/docs">Docs</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/api">API</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/blog">Blog</a>
        </li>
      </ul>
    </nav>

    <div class="header-actions">
      <a
        href="https://github.com/onedata"
        target="_blank"
        rel="noopener noreferrer"
        class="social-link"
        aria-label="GitHub"
      >
        <svg
          viewBox="0 0 24 24"
          width="24"
          height="24"
