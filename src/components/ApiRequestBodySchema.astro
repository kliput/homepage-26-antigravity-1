---
import { marked } from "marked";
import { resolveSchemaRef, type SchemaDefinition } from "../utils/openapi";
import ApiSchemaPropertyTree from "./ApiSchemaPropertyTree.astro";

export type RequestParameter = {
  name: string;
  in: string;
  description: string;
  schema: SchemaDefinition;
};

const requestParameter: RequestParameter = Astro.props.requestParameter;
const swaggerData: object = Astro.props.swaggerData;
const schema = resolveSchemaRef(requestParameter.schema, swaggerData);
const schemaProperties = Object.entries(schema?.properties || {});
---

<div class="od-bg-input overflow-hidden rounded-xl border">
  {
    requestParameter.description && (
      <div
        class="od-bg-2 border-b px-4 py-2 text-xs font-bold"
        set:html={marked.parse(requestParameter.description)}
      />
    )
  }
  {
    schemaProperties.length ? (
      <div class="overflow-x-auto p-4 text-sm">
        <ul class="m-0 list-none space-y-4 p-0">
          {schemaProperties.map(
            ([propName, propDef]: [string, SchemaDefinition]) => (
              <ApiSchemaPropertyTree
                name={propName}
                schema={propDef}
                swaggerData={swaggerData}
                isRequired={(schema?.required || []).includes(propName)}
              />
            ),
          )}
        </ul>
      </div>
    ) : (
      <div class="overflow-x-auto p-4 text-sm">
        <p class="text-gray-500">No schema provided.</p>
      </div>
    )
  }
</div>
