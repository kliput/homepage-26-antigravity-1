---
import { Database, HardDrive, Lock, Zap, Globe, Layers } from "@lucide/astro";

const features = [
  {
    icon: Database,
    title: "Unified Virtual Filesystem",
    description:
      "Mount any storage backend — S3, POSIX, Ceph, NFS — as a single global namespace. No data migration needed.",
    color: "from-red-500 to-orange-500",
    page: "/features/unified-virtual-filesystem",
  },
  {
    icon: Zap,
    title: "High-Performance Data Access",
    description:
      "Optimized for AI training workloads. Stream petabytes across WAN with minimal latency using our intelligent caching layer.",
    color: "from-rose-500 to-red-500",
    page: "/features/high-performance",
  },
  {
    icon: Globe,
    title: "Hybrid Cloud Ready",
    description:
      "Seamlessly span on-premises HPC clusters, AWS, GCP, Azure, and institutional storage in one unified environment.",
    color: "from-orange-500 to-amber-500",
    page: "/features/hybrid-cloud-ready",
  },
  {
    icon: HardDrive,
    title: "S3 & POSIX Hybrid Access",
    description:
      "Access the same dataset via a fully S3-compatible API or mount it as a native POSIX filesystem — no duplication, no trade-offs. Ideal for cloud-native pipelines and HPC workloads alike.",
    color: "from-red-600 to-rose-400",
    page: "/features/s3-posix",
  },
  {
    icon: Lock,
    title: "Fine-Grained Access Control",
    description:
      "Attribute-based access control per dataset, file, or directory. Built for multi-organization research collaborations.",
    color: "from-rose-600 to-pink-500",
    page: "/features/fine-grained",
  },
  {
    icon: Layers,
    title: "Space & Replication Policies",
    description:
      "Define exactly where and how many replicas of your data exist. Auto-balance storage across federated providers.",
    color: "from-red-500 to-rose-600",
    page: "/features/space-replication",
  },
];
---

<section id="features" class="features-section">
  <div class="container max-w-6xl">
    <div class="mb-16 text-center">
      <div class="features-pill">PLATFORM CAPABILITIES</div>
      <h2 class="features-title">
        Built for the complexity of <span class="gradient-text"
          >modern research</span
        >
      </h2>
      <p class="features-subtitle">
        Onedata addresses the real challenges of managing petabyte-scale
        datasets across heterogeneous compute and storage environments.
      </p>
    </div>

    <div class="features-grid">
      {
        features.map((feature) => {
          const Icon = feature.icon;
          return (
            <a href={feature.page} class="feature-card group">
              <div class={`feature-glow-bg bg-linear-to-br ${feature.color}`} />

              <div
                class={`feature-icon-wrapper bg-linear-to-br ${feature.color}`}
              >
                <Icon class="h-5 w-5 text-white" />
              </div>

              <h3 class="feature-card-title">{feature.title}</h3>
              <p class="feature-card-desc">{feature.description}</p>

              <div
                class={`feature-card-line bg-gradient-to-r ${feature.color}`}
              />
            </a>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 6rem 1rem;
    background-color: var(--color-bg);
  }

  .max-w-6xl {
    max-width: 72rem;
    margin: 0 auto;
  }

  .text-center {
    text-align: center;
  }
  .mb-16 {
    margin-bottom: 4rem;
  }

  .features-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    opacity: 0.7;
    font-size: 0.75rem;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    margin-bottom: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .features-title {
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--color-text);
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .features-title {
      font-size: 3rem;
    }
  }

  .gradient-text {
    background: linear-gradient(
      to right,
      var(--color-primary, #e11d48),
      #f43f5e
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  html[data-theme="dark"] .gradient-text {
    background: linear-gradient(to right, #fb7185, #fda4af);
    -webkit-background-clip: text;
  }

  .features-subtitle {
    color: var(--color-text);
    opacity: 0.7;
    max-width: 36rem;
    margin: 0 auto;
    line-height: 1.6;
    font-size: 1.125rem;
  }

  .features-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .feature-card {
    position: relative;
    border-radius: 1rem;
    padding: 1.5rem;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    cursor: pointer;
    overflow: hidden;
    transition:
      transform 0.3s,
      box-shadow 0.3s,
      border-color 0.3s;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .feature-card:hover {
    transform: translateY(-6px);
    box-shadow:
      0 20px 25px -5px rgba(0, 0, 0, 0.1),
      0 10px 10px -5px rgba(0, 0, 0, 0.04);
    text-decoration: none;
  }

  html[data-theme="dark"] .feature-card:hover {
    box-shadow:
      0 20px 25px -5px rgba(0, 0, 0, 0.4),
      0 10px 10px -5px rgba(0, 0, 0, 0.2);
  }

  .feature-glow-bg {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.3s;
    border-radius: 1rem;
    z-index: 0;
  }

  .feature-card:hover .feature-glow-bg {
    opacity: 0.05;
  }

  html[data-theme="dark"] .feature-card:hover .feature-glow-bg {
    opacity: 0.1;
  }

  .feature-icon-wrapper {
    display: inline-flex;
    padding: 0.625rem;
    border-radius: 0.75rem;
    opacity: 0.9;
    margin-bottom: 1rem;
    align-self: flex-start;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 1;
    position: relative;
  }

  .feature-card:hover .feature-icon-wrapper {
    transform: scale(1.1) rotate(5deg);
  }

  .feature-card-title {
    color: var(--color-text);
    font-weight: 600;
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
    z-index: 1;
    position: relative;
  }

  .feature-card-desc {
    color: var(--color-text);
    opacity: 0.7;
    font-size: 0.875rem;
    line-height: 1.6;
    z-index: 1;
    position: relative;
    flex-grow: 1;
  }

  .feature-card-line {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s;
    z-index: 1;
  }

  .feature-card:hover .feature-card-line {
    transform: scaleX(1);
  }

  /* Tailwind Gradient Utilities mapped to standard CSS */
  .bg-linear-to-br {
    background-image: linear-gradient(
      to bottom right,
      var(--tw-gradient-stops)
    );
  }
  .bg-linear-to-r {
    background-image: linear-gradient(to right, var(--tw-gradient-stops));
  }

  .from-red-500 {
    --tw-gradient-from: #ef4444;
    --tw-gradient-stops:
      var(--tw-gradient-from), var(--tw-gradient-to, rgba(239, 68, 68, 0));
  }
  .to-orange-500 {
    --tw-gradient-to: #f97316;
  }

  .from-rose-500 {
    --tw-gradient-from: #f43f5e;
    --tw-gradient-stops:
      var(--tw-gradient-from), var(--tw-gradient-to, rgba(244, 63, 94, 0));
  }
  .to-red-500 {
    --tw-gradient-to: #ef4444;
  }

  .from-orange-500 {
    --tw-gradient-from: #f97316;
    --tw-gradient-stops:
      var(--tw-gradient-from), var(--tw-gradient-to, rgba(249, 115, 22, 0));
  }
  .to-amber-500 {
    --tw-gradient-to: #f59e0b;
  }

  .from-red-600 {
    --tw-gradient-from: #dc2626;
    --tw-gradient-stops:
      var(--tw-gradient-from), var(--tw-gradient-to, rgba(220, 38, 38, 0));
  }
  .to-rose-400 {
    --tw-gradient-to: #fb7185;
  }

  .from-rose-600 {
    --tw-gradient-from: #e11d48;
    --tw-gradient-stops:
      var(--tw-gradient-from), var(--tw-gradient-to, rgba(225, 29, 72, 0));
  }
  .to-pink-500 {
    --tw-gradient-to: #ec4899;
  }

  .to-rose-600 {
    --tw-gradient-to: #e11d48;
  }
</style>
