---
import MainLayout from "../layouts/MainLayout.astro";
import LandingContact from "../components/LandingContact.astro";

interface Props {
  title: string;
  description: string;
  icon: any;
  gradient: string;
  image: string;
  benefits: string[];
}

const {
  title,
  description,
  icon: Icon,
  gradient,
  image,
  benefits,
} = Astro.props;
---

<MainLayout title={`${title} — Onedata`} description={description}>
  <div class="feature-page">
    <section class="feature-hero">
      <div class="container max-w-4xl">
        <a href="/" class="back-link">
          <svg
            width="16"
            height="16"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 12H5M12 19l-7-7 7-7"></path>
          </svg>
          Back to home
        </a>
        <div class={`icon-wrap ${gradient}`}>
          <Icon class="feature-icon" />
        </div>
        <h1 class="feature-title">{title}</h1>
        <p class="feature-desc">{description}</p>
      </div>
    </section>

    <section class="feature-content">
      <div class="container max-w-4xl">
        <div class="content-card">
          <img src={image} alt={title} class="feature-image" />
          <div class="benefits-section">
            <h2 class="benefits-heading">Key Benefits</h2>
            <ul class="benefits-list">
              {
                benefits.map((b) => (
                  <li class="benefit-item">
                    <span class="benefit-dot">•</span>
                    <span>{b}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </section>

    <LandingContact />
  </div>
</MainLayout>

<style>
  .feature-page {
    min-height: 100vh;
  }

  .feature-hero {
    padding: 4rem 1rem 3rem;
    background-color: var(--color-bg);
  }

  .max-w-4xl {
    max-width: 56rem;
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text);
    opacity: 0.5;
    font-size: 0.875rem;
    text-decoration: none;
    margin-bottom: 2rem;
    transition: opacity 0.2s;
  }

  .back-link:hover {
    opacity: 0.9;
    text-decoration: none;
  }

  .icon-wrap {
    display: inline-flex;
    padding: 0.75rem;
    border-radius: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .from-red-500-to-orange-500 {
    background: linear-gradient(135deg, #ef4444, #f97316);
  }
  .from-rose-500-to-red-500 {
    background: linear-gradient(135deg, #f43f5e, #ef4444);
  }
  .from-orange-500-to-amber-500 {
    background: linear-gradient(135deg, #f97316, #f59e0b);
  }
  .from-red-600-to-rose-400 {
    background: linear-gradient(135deg, #dc2626, #fb7185);
  }
  .from-rose-600-to-pink-500 {
    background: linear-gradient(135deg, #e11d48, #ec4899);
  }
  .from-red-500-to-rose-600 {
    background: linear-gradient(135deg, #ef4444, #e11d48);
  }

  .feature-icon {
    width: 1.5rem;
    height: 1.5rem;
    color: white;
  }

  .feature-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin-bottom: 1.25rem;
    color: var(--color-text);
    line-height: 1.2;
  }

  .feature-desc {
    font-size: 1.125rem;
    color: var(--color-text);
    opacity: 0.7;
    line-height: 1.7;
    max-width: 40rem;
    margin-bottom: 1rem;
  }

  .feature-content {
    padding: 3rem 1rem 6rem;
    background-color: var(--color-bg);
  }

  .content-card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 2rem;
    overflow: hidden;
  }

  .feature-image {
    width: 100%;
    height: 24rem;
    object-fit: cover;
    border-radius: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .benefits-heading {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .benefits-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .benefit-item {
    display: flex;
    gap: 0.75rem;
    color: var(--color-text);
    opacity: 0.75;
    align-items: flex-start;
  }

  .benefit-dot {
    color: var(--color-primary, #e11d48);
    font-weight: 700;
    flex-shrink: 0;
  }
</style>
