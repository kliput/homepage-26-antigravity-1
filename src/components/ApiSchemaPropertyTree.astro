---
import { marked } from "marked";
import {
  resolveSchemaRef,
  getSubclasses,
  getSubclassProperties,
  resolveAllOf,
  type SchemaDefinition,
} from "../utils/openapi";
import { ApiExpandArrow } from "./ApiExpandArrow.jsx";
import ApiBodyTag from "./ApiBodyTag.astro";
import ApiDiscriminatorSelect from "./ApiDiscriminatorSelect.astro";

export interface Props {
  name?: string;
  schema: SchemaDefinition;
  swaggerData: any;
  isRequired?: boolean;
  seenRefs?: string[];
  level?: number;
  initiallyOpened?: boolean;
  collapsed?: boolean;
  isDiscriminatorField?: boolean;
  discriminatorSchemaId?: string;
  discriminatorOptions?: { name: string; schema: SchemaDefinition }[];
}

const {
  name,
  schema: rawSchema,
  swaggerData,
  isRequired = false,
  seenRefs = [],
  level = 0,
  collapsed,
  isDiscriminatorField,
  discriminatorSchemaId: propsDiscriminatorSchemaId,
  discriminatorOptions,
} = Astro.props;

let { initiallyOpened } = Astro.props;

if (initiallyOpened === undefined) {
  if (typeof collapsed === "boolean") {
    initiallyOpened = !collapsed;
  } else {
    initiallyOpened = level < 1;
  }
}

if (!rawSchema) {
  // Silent return for invalid schemas
  return;
}

const refStr = rawSchema.$ref;
const schema = resolveSchemaRef(rawSchema, swaggerData) || rawSchema;

const currentSeenRefs = refStr ? [...seenRefs, refStr] : seenRefs;
const isCircular = refStr ? seenRefs.includes(refStr) : false;

let displayType = schema.type || "any";

if (schema.type === "array" && schema.items) {
  const itemRef = schema.items.$ref;
  const itemSchema =
    resolveSchemaRef(schema.items, swaggerData) || schema.items;
  const baseType =
    itemSchema.type || (itemSchema.properties ? "object" : "any");

  if (itemRef) {
    const modelName = itemRef.split("/").pop() || baseType;
    displayType = `array of ${baseType}s (${modelName})`;
  } else {
    displayType = `array of ${baseType}s`;
  }
} else if (refStr) {
  const modelName = refStr.split("/").pop();
  const baseType = schema.type || (schema.properties ? "object" : "any");
  displayType = modelName ? `${baseType} (${modelName})` : baseType;
} else if (!schema.type && schema.properties) {
  displayType = "object";
}
const currentModelName = refStr ? refStr.split("/").pop() : undefined;

const hasProperties =
  schema.properties && Object.keys(schema.properties).length > 0;
const isArrayOfObjects =
  schema.type === "array" &&
  schema.items &&
  (schema.items.properties || schema.items.$ref);

const childPropertiesSchema = hasProperties
  ? schema
  : isArrayOfObjects
    ? resolveSchemaRef(schema.items, swaggerData)
    : undefined;

const hasExpandableChildren =
  !isCircular &&
  childPropertiesSchema &&
  childPropertiesSchema.properties &&
  Object.keys(childPropertiesSchema.properties).length > 0;

const discriminatorField = childPropertiesSchema?.discriminator;
const subclasses = discriminatorField
  ? getSubclasses(childPropertiesSchema, swaggerData, currentModelName)
  : [];
const childDiscriminatorSchemaId = discriminatorField
  ? `disc-${Math.floor(Math.random() * 100000)}`
  : "";

// FIXME: śmieci po refaktorze SI
const Container = hasExpandableChildren ? "details" : "div";
const HeaderWrapper = hasExpandableChildren ? "summary" : "div";

const detailsElementId = `api-details-${Math.floor(Math.random() * 10000)}`;
---

{
  rawSchema && (
    <tr class="api-schema-property-tree">
      <td colspan="2" class="border-none p-0">
        <Container class="group" open={initiallyOpened} id={detailsElementId}>
          <HeaderWrapper
            class:list={[
              "list-none outline-none",
              hasExpandableChildren ? "cursor-pointer" : "",
            ]}
          >
            <div class="hover:bg-[var(--od-bg-input)]/50 flex w-full items-start py-3 transition-colors">
              <div
                class="flex w-1/3 flex-wrap items-center gap-2 pl-0 pr-3 font-mono text-sm font-medium"
                style="overflow-wrap: anywhere;"
              >
                {name && <span>{name}</span>}
                {isRequired && <ApiBodyTag colorStyle="red" text="required" />}
                {isCircular && (
                  <ApiBodyTag colorStyle="yellow" text="circular reference" />
                )}
                {hasExpandableChildren && (
                  <ApiExpandArrow
                    client:only
                    detailsElementId={detailsElementId}
                  />
                )}
              </div>
              <div class="w-2/3 pr-4">
                {!isDiscriminatorField ? (
                  <>
                    <div class="font-mono text-xs font-normal text-[var(--od-text-muted)]">
                      {displayType}
                    </div>
                    {schema.description && (
                      <div
                        class="prose prose-sm mt-1.5 leading-snug opacity-90 dark:prose-invert"
                        set:html={marked.parse(schema.description)}
                      />
                    )}
                    {schema.enum && schema.enum.length > 0 && (
                      <div class="mt-2 font-mono text-xs text-[var(--od-text-muted)]">
                        <span class="font-semibold">Enum:</span>
                        <div class="mt-1 flex flex-wrap gap-1.5">
                          {schema.enum.map((val: any) => (
                            <span class="inline-block rounded border border-[var(--od-border)] bg-[var(--od-bg-input)] px-1.5 py-0.5 text-[var(--od-text)]">
                              {typeof val === "string"
                                ? val
                                : JSON.stringify(val)}
                            </span>
                          ))}
                        </div>
                      </div>
                    )}
                  </>
                ) : (
                  <>
                    {discriminatorOptions &&
                      propsDiscriminatorSchemaId &&
                      discriminatorOptions.map((opt, index) => {
                        const subSchemaMerged = resolveAllOf(
                          opt.schema,
                          swaggerData,
                        );
                        const subSchemaProperty =
                          subSchemaMerged?.properties?.[name || ""] || schema;
                        const subDisplayType = subSchemaProperty.type || "any";

                        return (
                          <div
                            data-discriminator-parent={
                              propsDiscriminatorSchemaId
                            }
                            data-discriminator-value={opt.name}
                            style={index === 0 ? "" : "display: none;"}
                          >
                            <div class="mb-1.5 font-mono text-xs font-normal text-[var(--od-text-muted)]">
                              discriminator {subDisplayType}
                            </div>
                            <ApiDiscriminatorSelect
                              schemaId={propsDiscriminatorSchemaId}
                              options={discriminatorOptions.map((sc) => ({
                                name: sc.name,
                                label: sc.name,
                              }))}
                            />
                            {subSchemaProperty.description && (
                              <div
                                class="prose prose-sm mt-3 leading-snug opacity-90 dark:prose-invert"
                                set:html={marked.parse(
                                  subSchemaProperty.description,
                                )}
                              />
                            )}
                          </div>
                        );
                      })}
                  </>
                )}
              </div>
            </div>
          </HeaderWrapper>

          {hasExpandableChildren && (
            <div class="ml-6 pl-3">
              <table class="mb-6 w-full table-fixed border-collapse">
                <tbody class="divide-y divide-[var(--od-border)] border-t">
                  {childPropertiesSchema?.properties &&
                    Object.entries(childPropertiesSchema.properties).map(
                      ([propName, propDef]: [string, any]) => (
                        <Astro.self
                          name={propName}
                          schema={propDef}
                          swaggerData={swaggerData}
                          isRequired={(
                            childPropertiesSchema.required || []
                          ).includes(propName)}
                          seenRefs={currentSeenRefs}
                          level={level + 1}
                          isDiscriminatorField={propName === discriminatorField}
                          discriminatorSchemaId={
                            propName === discriminatorField
                              ? childDiscriminatorSchemaId
                              : undefined
                          }
                          discriminatorOptions={
                            propName === discriminatorField
                              ? subclasses
                              : undefined
                          }
                        />
                      ),
                    )}
                </tbody>
                {discriminatorField &&
                  subclasses.map((sc) => {
                    const subclassProps = getSubclassProperties(
                      childPropertiesSchema,
                      sc.schema,
                      swaggerData,
                    );
                    if (Object.keys(subclassProps).length === 0) return null;

                    const requiredProps =
                      resolveSchemaRef(sc.schema, swaggerData)?.required || [];
                    return (
                      <tbody
                        class="divide-y divide-[var(--od-border)] border-t"
                        data-discriminator-parent={childDiscriminatorSchemaId}
                        data-discriminator-value={sc.name}
                        style="display: none;"
                      >
                        {Object.entries(subclassProps).map(
                          ([propName, propDef]: [string, any]) => (
                            <Astro.self
                              name={propName}
                              schema={propDef}
                              swaggerData={swaggerData}
                              isRequired={requiredProps.includes(propName)}
                              seenRefs={currentSeenRefs}
                              level={level + 1}
                            />
                          ),
                        )}
                      </tbody>
                    );
                  })}
              </table>
            </div>
          )}
        </Container>
      </td>
    </tr>
  )
}
