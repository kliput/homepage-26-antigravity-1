---
import { marked } from "marked";
import { resolveSchemaRef, type SchemaDefinition } from "../utils/openapi";
import ApiExpandArrow from "./ApiExpandArrow.astro";

export interface Props {
  name?: string;
  schema: SchemaDefinition;
  swaggerData: any;
  isRequired?: boolean;
  seenRefs?: string[];
  level?: number;
}

const {
  name,
  schema: rawSchema,
  swaggerData,
  isRequired = false,
  seenRefs = [],
  level = 0,
} = Astro.props;

if (!rawSchema) {
  // Silent return for invalid schemas
  return;
}

const refStr = rawSchema.$ref;
const schema = resolveSchemaRef(rawSchema, swaggerData) || rawSchema;

const currentSeenRefs = refStr ? [...seenRefs, refStr] : seenRefs;
const isCircular = refStr ? seenRefs.includes(refStr) : false;

let displayType = schema.type || "any";

if (schema.type === "array" && schema.items) {
  const itemRef = schema.items.$ref;
  const itemSchema =
    resolveSchemaRef(schema.items, swaggerData) || schema.items;
  const baseType =
    itemSchema.type || (itemSchema.properties ? "object" : "any");

  if (itemRef) {
    const modelName = itemRef.split("/").pop() || baseType;
    displayType = `array of ${baseType}s (${modelName})`;
  } else {
    displayType = `array of ${baseType}s`;
  }
} else if (refStr) {
  const modelName = refStr.split("/").pop();
  const baseType = schema.type || (schema.properties ? "object" : "any");
  displayType = modelName ? `${baseType} (${modelName})` : baseType;
} else if (!schema.type && schema.properties) {
  displayType = "object";
}

const hasProperties =
  schema.properties && Object.keys(schema.properties).length > 0;
const isArrayOfObjects =
  schema.type === "array" &&
  schema.items &&
  (schema.items.properties || schema.items.$ref);

const childPropertiesSchema = hasProperties
  ? schema
  : isArrayOfObjects
    ? resolveSchemaRef(schema.items, swaggerData)
    : undefined;

const hasExpandableChildren =
  !isCircular &&
  childPropertiesSchema &&
  childPropertiesSchema.properties &&
  Object.keys(childPropertiesSchema.properties).length > 0;

// Adding vertical lines for tree depth spacing visually instead of nested paddings on ul
const Container = hasExpandableChildren ? "details" : "div";
const HeaderWrapper = hasExpandableChildren ? "summary" : "div";
---

{
  rawSchema && (
    <tr class="api-schema-property-tree">
      <td colspan="2" class="border-none p-0">
        <details class="group" open={level < 1}>
          <summary
            class:list={[
              "cursor-pointer list-none outline-none",
              !hasExpandableChildren && "pointer-events-none",
            ]}
          >
            <div class="hover:bg-[var(--od-bg-input)]/50 flex w-full items-start py-3 transition-colors">
              <div class="flex w-1/3 items-center gap-2 pl-3 pr-3 font-mono text-sm font-medium">
                {name && <span>{name}</span>}
                {isRequired && (
                  <span class="rounded bg-red-500/10 px-1.5 py-0.5 text-[10px] font-bold uppercase text-red-500">
                    required
                  </span>
                )}
                {isCircular && (
                  <span
                    class="rounded bg-yellow-500/10 px-1.5 py-0.5 text-[10px] font-bold uppercase text-yellow-500"
                    title="Circular reference"
                  >
                    circular
                  </span>
                )}
                {hasExpandableChildren && <ApiExpandArrow />}
              </div>
              <div class="w-2/3 pr-4">
                <div class="font-mono text-xs font-normal text-[var(--od-text-muted)]">
                  {displayType}
                </div>
                {schema.description && (
                  <div
                    class="prose prose-sm mt-1.5 leading-snug opacity-90 dark:prose-invert"
                    set:html={marked.parse(schema.description)}
                  />
                )}
                {schema.enum && schema.enum.length > 0 && (
                  <div class="mt-2 font-mono text-xs text-[var(--od-text-muted)]">
                    <span class="font-semibold">Enum:</span>
                    <div class="mt-1 flex flex-wrap gap-1.5">
                      {schema.enum.map((val: any) => (
                        <span class="inline-block rounded border border-[var(--od-border)] bg-[var(--od-bg-input)] px-1.5 py-0.5 text-[var(--od-text)]">
                          {typeof val === "string" ? val : JSON.stringify(val)}
                        </span>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </div>
          </summary>

          {hasExpandableChildren && (
            <div class="ml-6 pl-3">
              <table class="mb-6 w-full table-fixed border-collapse">
                <tbody class="divide-y divide-[var(--od-border)]">
                  {childPropertiesSchema?.properties &&
                    Object.entries(childPropertiesSchema.properties).map(
                      ([propName, propDef]: [string, any]) => (
                        <Astro.self
                          name={propName}
                          schema={propDef}
                          swaggerData={swaggerData}
                          isRequired={(
                            childPropertiesSchema.required || []
                          ).includes(propName)}
                          seenRefs={currentSeenRefs}
                          level={level + 1}
                        />
                      ),
                    )}
                </tbody>
              </table>
            </div>
          )}
        </details>
      </td>
    </tr>
  )
}
