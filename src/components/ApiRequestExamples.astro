---
import { resolveSchemaRef } from "../utils/openapi";

const { operation, swaggerData } = Astro.props;

const codeSamples = operation.details["x-code-samples"] || [];
const bodyParam = operation.details.parameters?.find(
  (p: any) => p.in === "body",
);

let payloadExampleHTML: string | null = null;
let hasJsonPayloadExample = false;

if (bodyParam && bodyParam.schema) {
  const schema = resolveSchemaRef(bodyParam.schema, swaggerData);
  // Also check if operation body has schema example directly or via $ref
  let exampleObj = schema?.example;

  if (!exampleObj && bodyParam.schema.example) {
    exampleObj = bodyParam.schema.example;
  }

  if (exampleObj) {
    hasJsonPayloadExample = true;
    payloadExampleHTML =
      typeof exampleObj === "string"
        ? exampleObj
        : JSON.stringify(exampleObj, null, 2);
    payloadExampleHTML = payloadExampleHTML?.trim();
  }
}

const hasShellExample = codeSamples.length > 0;
const shouldRender = hasShellExample || hasJsonPayloadExample;
---

{
  shouldRender && (
    <div class="api-section mt-12">
      <h2>Request Examples</h2>

      <api-request-examples class="mt-4 block">
        <div class="mb-4 flex gap-2 border-b border-[var(--od-border)]">
          {hasJsonPayloadExample && (
            <button
              class:list={[
                "tab-btn border-b-2 px-4 py-2 text-sm font-semibold transition-colors hover:text-[var(--od-accent)]",
                "active border-[var(--od-accent)] text-[var(--od-text)]",
              ]}
              data-target="payload-example"
            >
              JSON Payload
            </button>
          )}
          {hasShellExample && (
            <button
              class:list={[
                "tab-btn border-b-2 px-4 py-2 text-sm font-semibold transition-colors hover:text-[var(--od-accent)]",
                !hasJsonPayloadExample
                  ? "active border-[var(--od-accent)] text-[var(--od-text)]"
                  : "border-transparent text-[var(--od-text-muted)]",
              ]}
              data-target="shell-examples"
            >
              Shell
            </button>
          )}
        </div>

        <div class="tab-contents relative">
          {hasJsonPayloadExample && (
            <div class="tab-pane active space-y-6" id="payload-example">
              <div class="overflow-hidden rounded-xl border border-[#2d2d2d] bg-[#1e1e1e]">
                <div class="border-b border-[#404040] bg-[#2d2d2d] px-4 py-2 font-mono text-xs text-gray-300">
                  application/json
                </div>
                <div class="overflow-x-auto p-4 text-sm text-gray-300">
                  {/* prettier-ignore */}
                  <pre><code>{payloadExampleHTML}</code></pre>
                </div>
              </div>
            </div>
          )}

          {hasShellExample && (
            <div
              class:list={[
                "tab-pane space-y-6",
                !hasJsonPayloadExample ? "active" : "hidden",
              ]}
              id="shell-examples"
            >
              {codeSamples.map((sample: any) => (
                <div class="overflow-hidden rounded-xl border border-[#2d2d2d] bg-[#1e1e1e]">
                  <div class="border-b border-[#404040] bg-[#2d2d2d] px-4 py-2 text-xs font-bold text-gray-300">
                    {sample.lang}
                  </div>
                  <div class="overflow-x-auto break-all p-4 text-sm">
                    <code class="text-gray-300">{sample.source}</code>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      </api-request-examples>
    </div>
  )
}

<script>
  class ApiRequestExamples extends HTMLElement {
    constructor() {
      super();
      const buttons = this.querySelectorAll(".tab-btn");
      const panes = this.querySelectorAll(".tab-pane");

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          // Reset all tabs
          buttons.forEach((b) => {
            b.classList.remove(
              "active",
              "border-[var(--od-accent)]",
              "text-[var(--od-text)]",
            );
            b.classList.add(
              "border-transparent",
              "text-[var(--od-text-muted)]",
            );
          });
          panes.forEach((p) => p.classList.add("hidden"));

          // Set active tab
          btn.classList.add(
            "active",
            "border-[var(--od-accent)]",
            "text-[var(--od-text)]",
          );
          btn.classList.remove(
            "border-transparent",
            "text-[var(--od-text-muted)]",
          );

          const targetId = btn.getAttribute("data-target");
          if (targetId) {
            const targetPane = this.querySelector(`#${targetId}`);
            if (targetPane) {
              targetPane.classList.remove("hidden");
            }
          }
        });
      });
    }
  }

  // Only define the custom element if it hasn't been defined yet
  if (!customElements.get("api-request-examples")) {
    customElements.define("api-request-examples", ApiRequestExamples);
  }
</script>
