---
import DocsVersionSelect from "../components/DocsVersionSelect.astro";
import ApiSidebarItem from "../components/ApiSidebarItem.astro";
import MainLayout from "./MainLayout.astro";
import { Globe, Database, Settings, ChevronDown } from "lucide-astro";
import { ApiVersionManager } from "../utils/api/api";
import SidebarHeightController from "../components/SidebarHeightController.astro";

interface Props {
  title: string;
  version: string;
  activeProduct: string;
  sidebarGroups: any[];
}

const products = [
  { id: "onezone", label: "Onezone REST API", icon: Globe },
  { id: "oneprovider", label: "Oneprovider REST API", icon: Database },
  { id: "onepanel", label: "Onepanel REST API", icon: Settings },
];

const { title, version, activeProduct, sidebarGroups } = Astro.props;

// Current path for active state highlighting
const currentPath = Astro.url.pathname;

const versionManager = new ApiVersionManager();
const availableVersions = versionManager.getVersions();
const stableVersion = versionManager.getStableVersion();
const latestVersion = versionManager.getLatestVersion();

export function isActivePath(href: string, currentPath: string) {
  function normalizePath(p: string) {
    return p.replace(/\/+$/, "");
  }

  return normalizePath(currentPath) === normalizePath(href);
}
---

<MainLayout title={title}>
  <div class="docs-page">
    {/* Hero bar */}
    <div class="docs-hero-bar">
      <div class="docs-inner docs-inner--pt">
        <div class="flex items-center justify-between gap-4">
          <div class="min-w-0">
            <h1 class="hero-title">Onedata API Reference</h1>
            <p class="hero-subtitle">
              REST API references for Onezone, Oneprovider, and Onepanel.
            </p>
          </div>
          <DocsVersionSelect
            selectorId="api-version-select"
            version={version}
            availableVersions={availableVersions}
            stableVersion={stableVersion}
            latestVersion={latestVersion}
            pathPrefix="/api"
            pathSuffix="onezone/"
          />
        </div>
      </div>
    </div>

    {/* Product tabs bar */}
    <div class="docs-tabs-bar">
      <div class="docs-inner">
        <div class="docs-tabs-row">
          {
            products.map((product) => {
              const Icon = product.icon;
              const isActive = activeProduct === product.id;
              return (
                <a
                  href={`/api/${version}/${product.id}/`}
                  class={`chapter-tab ${isActive ? "active" : ""}`}
                >
                  <Icon class="tab-icon" />
                  {product.label}
                </a>
              );
            })
          }
        </div>
      </div>
    </div>

    {/* Body: sidebar + content */}
    <div class="docs-inner docs-body">
      <div class="docs-body-row">
        {/* Desktop sidebar */}
        <aside class="docs-sidebar docs-sidebar-initial api-sidebar">
          <nav
            data-overlayscrollbars-initialize
            class="sidebar-nav overlayscrollbar-element"
          >
            <ul class="sidebar-root-list">
              <li class="mb-2">
                <a
                  href={`/api/${version}/${activeProduct}/`}
                  class={`api-method-link ${isActivePath(`/api/${version}/${activeProduct}`, currentPath) || isActivePath(`/api/${version}/${activeProduct}/`, currentPath) ? "active" : ""}`}
                >
                  <span class="font-semibold" style="font-size: 0.95rem;">
                    Overview & Authentication
                  </span>
                </a>
              </li>
              {
                sidebarGroups.map((group) => {
                  const isExpanded = group.operations.some((op: any) =>
                    isActivePath(op.href, currentPath),
                  );
                  return (
                    <li
                      class={`sidebar-folder ${isExpanded ? "expanded" : ""}`}
                    >
                      <button class="folder-toggle">
                        {group.name}
                        <ChevronDown class="chevron" />
                      </button>
                      <ul
                        class="folder-contents"
                        style={{ display: isExpanded ? "block" : "none" }}
                      >
                        {group.operations.map((operation: any) => (
                          <ApiSidebarItem
                            operation={operation}
                            isActivePath={isActivePath}
                          />
                        ))}
                      </ul>
                    </li>
                  );
                })
              }
            </ul>
          </nav>
        </aside>

        {/* Mobile toggle */}
        <div class="docs-mobile-toggle">
          <button id="mobile-sidebar-toggle" class="mobile-nav-btn">
            Browse API Endpoints
          </button>
        </div>

        {/* Main content */}
        <main class="docs-main-content od-card od-card-main">
          <slot />
        </main>
      </div>
    </div>
  </div>
</MainLayout>

<style is:global>
  /* Sidebar */

  .sidebar-root-list a.api-method-link {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding-top: 0.25rem;
    padding-bottom: 0.25rem;
  }

  .api-method-link:hover {
    color: var(--od-text);
    text-decoration: none;
  }

  .api-method-link.active {
    color: var(--od-accent);
    font-weight: 600;
  }

  .method-badge {
    --method-badge-bg-opacity: 0.15;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    display: inline-flex;
    justify-content: center;
    border-width: 1px;
    color: var(--od-text-muted);
    background-color: var(--od-bg-2);
    border-color: var(--od-border);
  }

  .method-get {
    background-color: hsla(210, 99%, 69%, var(--method-badge-bg-opacity));
  }
  .method-post {
    background-color: hsla(135, 56%, 54%, var(--method-badge-bg-opacity));
  }
  .method-put {
    background-color: hsl(166, 70%, 50%, var(--method-badge-bg-opacity));
  }
  .method-delete {
    background-color: hsla(0, 84%, 60%, var(--method-badge-bg-opacity));
  }
  .method-patch {
    background-color: hsla(33, 97%, 59%, var(--method-badge-bg-opacity));
    /* background-color: hsla(33, 97%, 59%, 0.15); */
  }

  /* API detail styles */
  .api-endpoint-title {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    color: var(--od-text);
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const folders = document.querySelectorAll(".folder-toggle");
    folders.forEach((folder) => {
      folder.addEventListener("click", (e: Event) => {
        const target = e.currentTarget as HTMLElement;
        if (!target) return;
        const li = target.parentElement;
        if (!li) return;
        const ul = li.querySelector(".folder-contents") as HTMLElement;
        if (!ul) return;

        if (li.classList.contains("expanded")) {
          li.classList.remove("expanded");
          ul.style.display = "none";
        } else {
          li.classList.add("expanded");
          ul.style.display = "block";
        }
      });
    });
  });
</script>

<SidebarHeightController />
