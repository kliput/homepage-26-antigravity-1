---
import DocsVersionSelect from "../components/DocsVersionSelect.astro";
import ApiSidebarItem from "../components/ApiSidebarItem.astro";
import MainLayout from "./MainLayout.astro";
import {
  Globe,
  Database,
  Settings,
  ChevronDown,
  ExternalLink,
} from "lucide-astro";

interface Props {
  title: string;
  version: string;
  availableVersions: string[];
  activeProduct: string;
  sidebarGroups: any[];
}

const products = [
  { id: "onezone", label: "Onezone REST API", icon: Globe },
  { id: "oneprovider", label: "Oneprovider REST API", icon: Database },
  { id: "onepanel", label: "Onepanel REST API", icon: Settings },
];

const { title, version, availableVersions, activeProduct, sidebarGroups } =
  Astro.props;

// Current path for active state highlighting
const currentPath = Astro.url.pathname;

export function isActivePath(href: string, currentPath: string) {
  function normalizePath(p: string) {
    return p.replace(/\/+$/, "");
  }

  return normalizePath(currentPath) === normalizePath(href);
}
---

<MainLayout title={title}>
  <div class="docs-page">
    {/* Hero bar */}
    <div class="docs-hero-bar">
      <div class="docs-inner docs-inner--pt">
        <div class="flex items-center justify-between gap-4">
          <div class="min-w-0">
            <h1 class="hero-title">Onedata API Reference</h1>
            <p class="hero-subtitle">
              REST API references for Onezone, Oneprovider, and Onepanel.
            </p>
          </div>
          <DocsVersionSelect
            selectorId="api-version-select"
            version={version}
            availableVersions={availableVersions}
            pathPrefix="/api"
            pathSuffix="onezone/"
          />
        </div>
      </div>
    </div>

    {/* Product tabs bar */}
    <div class="docs-tabs-bar">
      <div class="docs-inner">
        <div class="docs-tabs-row">
          {
            products.map((product) => {
              const Icon = product.icon;
              const isActive = activeProduct === product.id;
              return (
                <a
                  href={`/api/${version}/${product.id}/`}
                  class={`chapter-tab ${isActive ? "active" : ""}`}
                >
                  <Icon class="tab-icon" />
                  {product.label}
                </a>
              );
            })
          }
        </div>
      </div>
    </div>

    {/* Body: sidebar + content */}
    <div class="docs-inner docs-body">
      <div class="docs-body-row">
        {/* Desktop sidebar */}
        <aside class="docs-sidebar api-sidebar">
          <div class="sticky top-32">
            <nav class="sidebar-nav pt-4">
              <ul class="sidebar-root-list">
                <li class="mb-2">
                  <a
                    href={`/api/${version}/${activeProduct}/`}
                    class={`api-method-link ${isActivePath(`/api/${version}/${activeProduct}`, currentPath) || isActivePath(`/api/${version}/${activeProduct}/`, currentPath) ? "active" : ""}`}
                  >
                    <span class="font-semibold" style="font-size: 0.95rem;">
                      Overview & Authentication
                    </span>
                  </a>
                </li>
                {
                  sidebarGroups.map((group) => {
                    const isExpanded = group.operations.some((op: any) =>
                      isActivePath(op.href, currentPath),
                    );
                    return (
                      <li
                        class={`sidebar-folder ${isExpanded ? "expanded" : ""}`}
                      >
                        <button class="folder-toggle">
                          {group.name}
                          <ChevronDown class="chevron" />
                        </button>
                        <ul
                          class="folder-contents"
                          style={{ display: isExpanded ? "block" : "none" }}
                        >
                          {group.operations.map((op: any) => (
                            <ApiSidebarItem
                              op={op}
                              isActivePath={isActivePath}
                            />
                          ))}
                        </ul>
                      </li>
                    );
                  })
                }
              </ul>
            </nav>
          </div>
        </aside>

        {/* Mobile toggle */}
        <div class="docs-mobile-toggle">
          <button id="mobile-sidebar-toggle" class="mobile-nav-btn">
            Browse API Endpoints
          </button>
        </div>

        {/* Main content */}
        <main class="docs-main-content od-card od-card-main">
          <slot />
        </main>
      </div>
    </div>
  </div>
</MainLayout>

<style is:global>
  /* Sidebar */

  .sidebar-root-list a.api-method-link {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding-top: 0.25rem;
    padding-bottom: 0.25rem;
  }

  .api-method-link:hover {
    color: var(--od-text);
    text-decoration: none;
  }

  .api-method-link.active {
    color: var(--od-accent);
    font-weight: 600;
  }

  .method-badge {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    background-color: var(--od-bg-2);
    color: var(--od-text-muted);
    border-color: var(--od-border);
    display: inline-flex;
    justify-content: center;
    border-width: 1px;
  }

  /* To customize various types of HTTP methods, use:
     method-get, method-post, method-put, method-delete, method-patch
  */

  /* API detail styles */
  .api-endpoint-title {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    color: var(--od-text);
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const folders = document.querySelectorAll(".folder-toggle");
    folders.forEach((folder) => {
      folder.addEventListener("click", (e: Event) => {
        const target = e.currentTarget as HTMLElement;
        if (!target) return;
        const li = target.parentElement;
        if (!li) return;
        const ul = li.querySelector(".folder-contents") as HTMLElement;
        if (!ul) return;

        if (li.classList.contains("expanded")) {
          li.classList.remove("expanded");
          ul.style.display = "none";
        } else {
          li.classList.add("expanded");
          ul.style.display = "block";
        }
      });
    });
  });
</script>
