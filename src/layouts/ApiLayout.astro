---
import DocsVersionSelect from "../components/DocsVersionSelect.astro";
import MainLayout from "./MainLayout.astro";
import {
  Globe,
  Database,
  Settings,
  ChevronDown,
  ExternalLink,
} from "lucide-astro";

interface Props {
  title: string;
  version: string;
  availableVersions: string[];
  activeProduct: string;
  sidebarGroups: any[];
}

const products = [
  { id: "onezone", label: "Onezone REST API", icon: Globe },
  { id: "oneprovider", label: "Oneprovider REST API", icon: Database },
  { id: "onepanel", label: "Onepanel REST API", icon: Settings },
];

const { title, version, availableVersions, activeProduct, sidebarGroups } =
  Astro.props;

// Current path for active state highlighting
const currentPath = Astro.url.pathname;
---

<MainLayout title={title}>
  <div class="docs-page">
    {/* Hero bar */}
    <div class="docs-hero-bar">
      <div class="docs-inner docs-inner--pt">
        <div class="flex items-center justify-between gap-4">
          <div class="min-w-0">
            <h1 class="hero-title">Onedata API Reference</h1>
            <p class="hero-subtitle">
              REST API references for Onezone, Oneprovider, and Onepanel.
            </p>
          </div>
          <DocsVersionSelect
            selectorId="api-version-select"
            version={version}
            availableVersions={availableVersions}
            pathPrefix="/api"
            pathSuffix="onezone/"
          />
        </div>
      </div>
    </div>

    {/* Product tabs bar */}
    <div class="docs-tabs-bar">
      <div class="docs-inner">
        <div class="docs-tabs-row">
          {
            products.map((product) => {
              const Icon = product.icon;
              const isActive = activeProduct === product.id;
              return (
                <a
                  href={`/api/${version}/${product.id}/`}
                  class={`product-tab ${isActive ? "active" : ""}`}
                >
                  <Icon class="tab-icon" />
                  {product.label}
                </a>
              );
            })
          }
        </div>
      </div>
    </div>

    {/* Body: sidebar + content */}
    <div class="docs-inner docs-body">
      <div class="docs-body-row">
        {/* Desktop sidebar */}
        <aside class="docs-sidebar">
          <div class="sticky top-32">
            <nav class="sidebar-nav pt-4">
              <ul class="sidebar-root-list">
                {
                  sidebarGroups.map((group) => {
                    const isExpanded = group.operations.some((op: any) =>
                      currentPath.endsWith(op.href),
                    );
                    return (
                      <li
                        class={`sidebar-folder ${isExpanded ? "expanded" : ""}`}
                      >
                        <button class="folder-toggle">
                          {group.name}
                          <ChevronDown class="chevron" />
                        </button>
                        <ul
                          class="folder-contents"
                          style={{ display: isExpanded ? "block" : "none" }}
                        >
                          {group.operations.map((op: any) => (
                            <li>
                              <a
                                href={op.href}
                                class={`api-method-link ${currentPath.endsWith(op.href) ? "active" : ""}`}
                              >
                                <span
                                  class={`method-badge method-${op.method}`}
                                >
                                  {op.method.toUpperCase()}
                                </span>
                                <span class="method-summary">
                                  {op.summary || op.method}
                                </span>
                              </a>
                            </li>
                          ))}
                        </ul>
                      </li>
                    );
                  })
                }
              </ul>
            </nav>
          </div>
        </aside>

        {/* Mobile toggle */}
        <div class="docs-mobile-toggle">
          <button id="mobile-sidebar-toggle" class="mobile-nav-btn">
            Browse API Endpoints
          </button>
        </div>

        {/* Main content */}
        <main class="docs-main-content od-card">
          <slot />
        </main>
      </div>
    </div>
  </div>
</MainLayout>

<style is:global>
  .hero-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--od-text);
    margin: 0;
  }

  .hero-subtitle {
    font-size: 0.75rem;
    color: var(--od-text-muted);
    margin-top: 0.125rem;
    margin-bottom: 0;
  }

  .product-tab {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--od-text-muted);
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: all 0.2s;
  }

  .product-tab:hover {
    color: var(--od-text);
    text-decoration: none;
  }

  .product-tab.active {
    color: var(--od-accent);
    border-bottom-color: var(--od-accent);
    font-weight: 600;
  }

  .tab-icon {
    width: 1rem;
    height: 1rem;
  }

  /* Sidebar */
  .api-sidebar ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-root-list > li {
    margin-bottom: 0.125rem;
  }

  .api-method-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    color: var(--od-text-muted);
    font-size: 0.875rem;
    border-radius: 0.5rem;
    transition: all 0.2s;
    min-width: 0;
  }

  .api-method-link:hover {
    color: var(--od-text);
    text-decoration: none;
  }

  .api-method-link.active {
    color: var(--od-accent);
    font-weight: 600;
  }

  .method-badge {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    min-width: 44px;
    text-align: center;
    flex-shrink: 0;
  }

  .method-get {
    background-color: rgba(97, 175, 254, 0.15);
    color: #61affe;
  }
  .method-post {
    background-color: rgba(73, 204, 144, 0.15);
    color: #49cc90;
  }
  .method-put {
    background-color: rgba(252, 161, 48, 0.15);
    color: #fca130;
  }
  .method-delete {
    background-color: rgba(249, 62, 62, 0.15);
    color: #f93e3e;
  }
  .method-patch {
    background-color: rgba(80, 227, 194, 0.15);
    color: #50e3c2;
  }

  .method-summary {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .folder-toggle {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    background: none;
    border: none;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--od-text-muted);
    cursor: pointer;
    border-radius: 0.5rem;
    transition: all 0.2s;
  }

  .sidebar-folder.expanded > .folder-toggle {
    color: var(--od-text);
  }

  .folder-toggle:hover {
    background-color: var(--od-bg-input);
  }

  .folder-toggle .chevron {
    width: 0.875rem;
    height: 0.875rem;
    transition: transform 0.2s;
    opacity: 0.5;
  }

  .sidebar-folder.expanded > .folder-toggle .chevron {
    transform: rotate(180deg);
    opacity: 1;
  }

  .folder-contents {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0.5rem 0.5rem;
    border-left: 1px solid var(--od-border);
  }

  .mobile-nav-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    background: var(--od-bg-card);
    border: 1px solid var(--od-border);
    color: var(--od-text);
    font-weight: 600;
    font-size: 0.875rem;
    cursor: pointer;
    width: 100%;
  }

  /* Content Card */
  .api-main-content {
    background-color: var(--od-bg-card);
    border: 1px solid var(--od-border);
    min-width: 0;
  }

  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* API detail styles */
  .api-endpoint-title {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    color: var(--od-text);
  }

  .api-endpoint-path {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
      "Courier New", monospace;
    background: var(--od-bg-input);
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    font-size: 0.9rem;
    margin-bottom: 2rem;
    border: 1px solid var(--od-border);
    color: var(--od-text);
    overflow-x: auto;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const folders = document.querySelectorAll(".folder-toggle");
    folders.forEach((folder) => {
      folder.addEventListener("click", (e: Event) => {
        const target = e.currentTarget as HTMLElement;
        if (!target) return;
        const li = target.parentElement;
        if (!li) return;
        const ul = li.querySelector(".folder-contents") as HTMLElement;
        if (!ul) return;

        if (li.classList.contains("expanded")) {
          li.classList.remove("expanded");
          ul.style.display = "none";
        } else {
          li.classList.add("expanded");
          ul.style.display = "block";
        }
      });
    });
  });
</script>
