---
import "../styles/markdown-containers.css";
import DocsVersionSelect from "../components/DocsVersionSelect.astro";
import MainLayout from "./MainLayout.astro";
import { Book, Users, Server, List, Globe } from "lucide-astro";
import type {
  SidebarNode,
  SidebarTree,
} from "../pages/docs/[version]/[chapter]/[...slug].astro";
import SidebarHeightController from "../components/SidebarHeightController.astro";

interface Props {
  title: string;
  version: string;
  availableVersions: string[];
  activeChapter: string;
  sidebarNodes: SidebarTree;
  showVersionSelector?: boolean;
}

type DocsChapterItem = {
  id: string;
  label: string;
  icon: any;
};

const chapters: DocsChapterItem[] = [
  { id: "intro", label: "Introduction", icon: Book },
  {
    id: "user-guide",
    label: "User Guide",
    icon: Users,
  },
  {
    id: "admin-guide",
    label: "Admin Guide",
    icon: Server,
  },
  { id: "glossary", label: "Glossary", icon: List },
  { id: "releases", label: "Releases", icon: Globe },
];

const {
  title,
  version,
  availableVersions,
  activeChapter,
  sidebarNodes,
  showVersionSelector = true,
}: Props = Astro.props;

const fallbackVersion = availableVersions[0];

// Helper to render sidebar recursively
function renderSidebarNode(node: SidebarNode, currentPath: string) {
  switch (node.type) {
    case "anchor":
      return `<li><a href="${node.href}" class="anchor-link">${node.label}</a></li>`;
    case "link": {
      const isActive =
        Astro.url.pathname === node.href ||
        Astro.url.pathname === node.href + "/";
      return `<li><a href="${node.href}" class="${isActive ? "active" : ""}">${node.label}</a></li>`;
    }
    case "heading": {
      let html = `<li class="sidebar-section-heading"><span class="sidebar-heading-label">${node.label}</span>`;
      if (node.children && node.children.length > 0) {
        html += `<ul class="sidebar-heading-list">`;
        for (const child of node.children) {
          html += renderSidebarNode(child, currentPath);
        }
        html += `</ul>`;
      }
      html += `</li>`;
      return html;
    }
    case "file": {
      const isActive =
        Astro.url.pathname === node.href ||
        Astro.url.pathname === node.href + "/";
      return `<li><a href="${node.href}" class="${isActive ? "active" : ""}">${node.label}</a></li>`;
    }
    case "dir": {
      // Check if any child is active to keep it open
      const isExpanded = (node.children ?? []).some(
        (child: SidebarNode) =>
          (child.href && Astro.url.pathname.includes(child.href)) ||
          (child.children &&
            child.children.some(
              (child: SidebarNode) =>
                child.href && Astro.url.pathname.includes(child.href),
            )),
      );

      let html = `
      <li class="sidebar-folder ${isExpanded ? "expanded" : ""}">
        <button class="folder-toggle">
          ${node.label}
          <svg class="chevron" viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
        <ul class="folder-contents" ${isExpanded ? 'style="display:block;"' : 'style="display:none;"'}>
    `;
      if (node.children) {
        for (const child of node.children) {
          html += renderSidebarNode(child, currentPath);
        }
      }
      html += `</ul></li>`;
      return html;
    }
    default:
      return "";
  }
}
---

<MainLayout title={title}>
  <div class="docs-page">
    {/* Hero bar */}
    <div class="docs-hero-bar">
      <div class="docs-inner docs-inner--pt">
        <div class="docs-hero-row">
          <div class="min-w-0">
            <h1 class="hero-title">Onedata Documentation</h1>
            <p class="hero-subtitle">
              Guides, API references, and examples for building with Onedata.
            </p>
          </div>
          {
            showVersionSelector && (
              <DocsVersionSelect
                selectorId="docs-version-select"
                version={version}
                availableVersions={availableVersions}
                pathPrefix="/docs"
                pathSuffix="intro/overview"
              />
            )
          }
        </div>
      </div>
    </div>

    {/* Section tabs bar */}
    <div class="docs-tabs-bar">
      <div class="docs-inner">
        <div class="docs-tabs-row">
          {
            chapters.map((chapter) => {
              const Icon = chapter.icon;
              const isActive = activeChapter === chapter.id;
              // Releases chapter is version-independent
              // FIXME: when on releases page, generate links with latest used version or stable or newest version available
              const href =
                chapter.id === "releases"
                  ? "/docs/releases"
                  : `/docs/${version ?? fallbackVersion}/${chapter.id}`;
              return (
                <a
                  href={href}
                  class={`chapter-tab ${isActive ? "active" : ""}`}
                >
                  <Icon class="tab-icon" />
                  {chapter.label}
                </a>
              );
            })
          }
        </div>
      </div>
    </div>

    {/* Body: sidebar + content */}
    <div class="docs-inner docs-body">
      <div class="docs-body-row">
        {/* Desktop sidebar */}
        <aside class="docs-sidebar">
          <div class="docs-sidebar-sticky-container">
            <nav
              data-overlayscrollbars-initialize
              class="sidebar-nav overlayscrollbar-element"
            >
              <ul class="sidebar-root-list">
                {
                  sidebarNodes.map((node) => (
                    <Fragment
                      set:html={renderSidebarNode(node, Astro.url.pathname)}
                    />
                  ))
                }
              </ul>
            </nav>
          </div>
        </aside>

        {/* Mobile sidebar toggle */}
        <div class="docs-mobile-toggle">
          <button id="mobile-sidebar-toggle" class="mobile-nav-btn">
            <List class="h-5 w-5" /> Browse Topics
          </button>
        </div>

        {/* Main content */}
        <main class="docs-main-content od-card od-card-main">
          <slot />
        </main>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { viewportOffsetTop } from "../utils/offset.mjs";

  // Script for toggling folders
  document.addEventListener("DOMContentLoaded", () => {
    const folders = document.querySelectorAll(".folder-toggle");
    folders.forEach((folder) => {
      folder.addEventListener("click", (e: Event) => {
        const target = e.currentTarget as HTMLElement;
        if (!target) return;
        const li = target.parentElement;
        if (!li) return;
        const ul = li.querySelector(".folder-contents") as HTMLElement;
        if (!ul) return;

        if (li.classList.contains("expanded")) {
          li.classList.remove("expanded");
          ul.style.display = "none";
        } else {
          li.classList.add("expanded");
          ul.style.display = "block";
        }
      });
    });

    // Copy anchor link to clipboard on click
    document.addEventListener("click", (e: Event) => {
      const target = (e.target as HTMLElement).closest(
        ".heading-anchor-link",
      ) as HTMLAnchorElement;
      if (target && target.href) {
        navigator.clipboard.writeText(target.href).catch((err) => {
          console.error("Failed to copy link: ", err);
        });
      }
    });

    // Update active anchor link on hash change
    function updateActiveAnchor() {
      const hash = window.location.hash;
      const anchorLinks = document.querySelectorAll(".anchor-link");
      if (!anchorLinks.length) return;

      anchorLinks.forEach((el) => {
        const link = el as HTMLAnchorElement;
        link.classList.remove("active");
        if (hash && link.hash === hash) {
          link.classList.add("active");
        } else if (!hash && link === anchorLinks[0]) {
          link.classList.add("active");
        }
      });
    }

    window.addEventListener("hashchange", updateActiveAnchor);
    updateActiveAnchor();
  });
</script>

<SidebarHeightController />

<style is:global>
  /* Release sidebar section styles */
  .sidebar-section-heading {
    margin-top: 1.5rem;
    padding: 0 0.75rem;
  }

  .sidebar-heading-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--od-text);
    opacity: 0.4;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .sidebar-heading-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sidebar-heading-list li a {
    padding-left: 0;
    padding-bottom: 0;
  }
</style>
